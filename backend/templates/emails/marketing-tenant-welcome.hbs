<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #f97316; color: white; padding: 24px; text-align: center; border-radius: 8px 8px 0 0; }
    .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 8px 8px; }
    .creds { background: white; padding: 16px; border-radius: 6px; margin: 16px 0; border: 1px solid #fed7aa; }
    .creds-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #fef3c7; }
    .creds-row:last-child { border-bottom: none; }
    .label { color: #666; }
    .value { font-weight: 600; }
    .pwd { font-family: 'Courier New', monospace; background: #fff7ed; padding: 4px 10px; border-radius: 4px; color: #c2410c; font-size: 14px; }
    .button { display: inline-block; padding: 12px 28px; background: #f97316; color: white !important; text-decoration: none; border-radius: 6px; margin: 16px 0; font-weight: 600; }
    .warn { background: #fef3c7; border-left: 3px solid #f59e0b; padding: 12px 14px; margin: 16px 0; color: #78350f; font-size: 14px; }
  </style>
</head>
<body>
  <div class="header"><h1>{{#if appName}}{{appName}} hesabınız hazır{{else}}Hesabınız hazır{{/if}}</h1></div>
  <div class="content">
    <p>Merhaba <strong>{{adminFirstName}}</strong>,</p>
    <p><strong>{{tenantName}}</strong> için hesabınız oluşturuldu. Aşağıdaki bilgilerle giriş yapabilirsiniz.</p>
    <div class="creds">
      <div class="creds-row"><span class="label">E-posta</span> <span class="value">{{adminEmail}}</span></div>
      <div class="creds-row"><span class="label">Geçici parola</span> <span class="value pwd">{{rawPassword}}</span></div>
    </div>
    <div class="warn">
      <strong>Güvenlik:</strong> İlk girişinizden sonra parolanızı mutlaka değiştirin.
      Unuttuysanız <a href="{{appUrl}}/forgot-password">/forgot-password</a> sayfasından sıfırlayabilirsiniz.
    </div>
    {{#if loginUrl}}
    <a href="{{loginUrl}}" class="button">Hesabıma giriş yap</a>
    {{/if}}
    <p>Saygılarımızla,<br>{{#if appName}}{{appName}} Ekibi{{else}}Ekibimiz{{/if}}</p>
  </div>
</body>
</html>
