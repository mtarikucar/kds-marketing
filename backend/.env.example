# ──────────────────────────────────────────────────────────────────────────
# Marketing service environment
# ──────────────────────────────────────────────────────────────────────────

# Postgres — the marketing-owned database (marketing_* tables, leads, offers,
# commissions, sales_calls, installation_*, sales_targets, outbox_events).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketing?schema=public

# Distributed rate-limit backing store (ioredis). When set, the throttle bucket
# is GLOBAL across replicas; when unset, each process keeps its own in-memory
# bucket — fine for a single replica, but it dilutes the global limit under >1
# (a "5/min" rule becomes 5×N). Use rediss:// for TLS and embed auth in the URL:
#   redis[s]://[:password@]host:6379
REDIS_URL=

# HTTP port. Convention: marketing runs on 3100 so it never collides with
# the core backend, which owns 3000 (CORE_SERVICE_URL below points there).
PORT=3100
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins.
CORS_ORIGIN=http://localhost:5173,http://localhost:5179

# ── Marketing auth realm (independent of core's JWT realms) ───────────────
# Both must be >= 32 chars in production and differ from each other.
MARKETING_JWT_SECRET=change-me-marketing-access-secret-32ch
MARKETING_JWT_REFRESH_SECRET=change-me-marketing-refresh-secret-32
# Optional: set only if you mirror core's realms here, used by the JwtModule
# factory's cross-realm distinctness check.
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# SUPERADMIN_JWT_SECRET=

# ── Service-to-service tokens ─────────────────────────────────────────────
# Static bearer token the AI research / CRM platform sends in `x-ingest-token`
# to POST /api/marketing/leads/ingest.

# Shared service token for /api/internal/* — BOTH directions:
#   - core → marketing: POST /api/internal/referral/resolve, /api/internal/events
#   - marketing → core: ${CORE_SERVICE_URL}/api/internal/provisioning/*
# Sent/checked via the `x-internal-token` header. Must match core's value.
INTERNAL_SERVICE_TOKEN=
# Platform (superadmin) realm JWT secret — operators are seeded via
# `npx ts-node prisma/seed-platform-operator.ts` (see that file's header).
PLATFORM_JWT_SECRET=
# Static token the nightly research routine presents on
# /api/internal/research/* (x-research-token). Separate principal from
# INTERNAL_SERVICE_TOKEN on purpose. Lead ingest uses per-workspace tokens
# minted in the panel (Research Settings) — no env for those.
RESEARCH_ROUTINE_TOKEN=
# Nightly cloud-routine surface (/api/internal/reviews/* and later content/
# insights/lead-scoring routines). Separate principal from RESEARCH_ROUTINE_TOKEN.
# RoutineTokenGuard fails closed when unset (routine endpoints 401).
ROUTINE_TOKEN=
# Per-workspace nightly cap on reviews the review-draft routine picks up.
ROUTINE_REVIEW_DAILY_CAP=50
# Per-workspace nightly cap on leads the lead-scoring routine scores.
ROUTINE_LEADSCORE_DAILY_CAP=100

# ── Billing / payment providers ─────────────────────────────────────────
# Manual bank-transfer path (always-on fallback; orders await operator
# approval in the platform console):
BANK_IBAN=
BANK_ACCOUNT_NAME=
# PayTR (TRY checkout, iframe):
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1
# Stripe (USD checkout, redirect):
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Agency rebilling / SaaS-mode (Epic D1) — the live outbound Stripe-Connect charge
# (agency charges its sub-account locations) is ENV-GATED on this Connect client id
# PLUS the STRIPE_SECRET_KEY above. When UNSET, rebilling still records internal
# settlement (DRAFT charges / owed amounts) but performs NO live charge — no crash.
# To go live: set STRIPE_CONNECT_CLIENT_ID + STRIPE_SECRET_KEY, and store each
# location's connected account id under its WorkspacePspConfig.configPublic.connectAccountId.
STRIPE_CONNECT_CLIENT_ID=

# Base URL of the core service (no trailing slash). Used by the
# HttpCoreProvisioningClient (lead → tenant provisioning, plan snapshots,
# orphan-reconciliation sweep).
CORE_SERVICE_URL=http://localhost:3000

# ── SMTP (EmailService — marketing tenant-welcome email) ─────────────────
# Leave unset to run in mock mode (emails are logged, not sent).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
# Product identity for outbound email + converted-tenant welcome links.
# APP_NAME brands the From: header and email copy; APP_URL is the core
# product's public URL (welcome email is skipped when APP_URL is unset).
APP_NAME=
APP_URL=
EMAIL_FROM_NAME=
# Used in links inside emails.
FRONTEND_URL=http://localhost:5173

# ── Phase F: AI core (GoHighLevel-class capabilities) ────────────────────
# Anthropic API key — powers Conversation/Content/Voice AI, Agent Studio and
# Ask AI. Without it the AI surfaces report "not configured" (compose 503s,
# the engine no-ops); the rest of the app runs normally. Boot logs a loud
# warning in production if it's unset and AI_DISABLED is not 1.
ANTHROPIC_API_KEY=
# Model tiers. Defaults shown; override per deploy. The default tier handles
# replies/compose/voice; the light tier handles cheap classification.
AI_MODEL_DEFAULT=claude-opus-4-8
AI_MODEL_LIGHT=claude-haiku-4-5
# Model for inbound customer conversation replies (conversation.reply/followup).
# Defaults to Haiku (fast + cheap; replies are short + KB-grounded). Set to
# claude-sonnet-4-6 or claude-opus-4-8 to A/B without a code change.
AI_MODEL_CONVERSATION=claude-haiku-4-5
# Kill-switch — set to 1 to hard-disable every AI call (cost incident lever).
AI_DISABLED=
# AES-256-GCM master key that seals per-workspace channel/PSP secrets AND mints
# the NetGSM inbound-SMS (MO) callback tokens. Must be a base64-encoded 32 bytes:
#   openssl rand -base64 32
# REQUIRED in production (boot fails fast without it); optional only in dev. When
# set it is format-validated at boot.
MARKETING_SECRET_KEY=
# Public base URL of THIS marketing service (no trailing slash) — used in
# tracking/pay/booking/voice links + Twilio signature verification (P2+).
PUBLIC_BASE_URL=
# Meta (WhatsApp/Instagram/Messenger) webhook (P2).
# META_APP_SECRET is used BOTH to verify inbound webhook X-Hub-Signature-256 AND
# to compute the appsecret_proof appended to every authenticated outbound Graph
# call (messaging/social/ads/reviews). Meta's "Require app secret proof for
# server API calls" defaults ON, so this must be set for outbound calls to work.
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
# Graph API version for ALL Meta Graph calls. Defaults to v19.0 when unset.
# Recommended: set to v23.0 — v19.0 is past Meta's ~2-year deprecation window.
GRAPH_API_VERSION=
# Where uploaded white-label logos are written (P10); served at
# /api/public/uploads. Mount a volume here in docker-compose.
UPLOADS_DIR=./uploads

# ── GHL-parity integrations (optional, env-gated) ────────────────────────
# All vars in this section are OPTIONAL. Each integration is completely inert
# (returns "not configured" / 400) when its required var(s) are absent — the
# app boots and operates normally without any of them.
#
# MARKETING_PUBLIC_URL — shared base-URL fallback used by SSO and Google
# Calendar to derive their OAuth redirect URIs when the integration-specific
# override is not set. Set to the public HTTPS origin of this service
# (no trailing slash). Superseded by SSO_REDIRECT_URI / GOOGLE_OAUTH_REDIRECT_URI
# when those are present.
MARKETING_PUBLIC_URL=
#
# ── SSO / OIDC ────────────────────────────────────────────────────────────
# Unlocks the per-workspace SSO/OIDC integration (authorization-code + PKCE,
# JIT user provisioning). The IdP client is configured IN-APP by the workspace
# admin — no env required for the IdP side. This var only overrides the
# redirect URI base when different from MARKETING_PUBLIC_URL.
# INERT when unset — SSO admin mutations return 400 "SSO not configured".
SSO_REDIRECT_URI=
#
# ── Google Calendar 2-way sync ────────────────────────────────────────────
# Unlocks Google Calendar OAuth connect + 2-way event sync (per-workspace).
# Requires MARKETING_SECRET_KEY to also be set (tokens are sealed at rest).
# Obtain credentials at https://console.cloud.google.com → APIs & Services →
# OAuth 2.0 Client IDs (web application). Add the callback URL
#   <MARKETING_PUBLIC_URL>/api/marketing/integrations/google-calendar/callback
# as an Authorized Redirect URI in the Google Cloud Console.
# INERT when unset — connect-start + admin mutations return 400.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: override the exact redirect URI registered in Google Cloud Console.
# When unset, the URI is derived from MARKETING_PUBLIC_URL (preferred) or
# PUBLIC_BASE_URL. Only set if your registered URI differs.
# GOOGLE_OAUTH_REDIRECT_URI=
#
# ── Social Planner (Meta + LinkedIn) ─────────────────────────────────────
# Unlocks scheduled multi-network social publishing (Facebook, Instagram,
# LinkedIn). Access tokens are connected per-workspace via the Social Planner
# settings UI and sealed with MARKETING_SECRET_KEY.
# META_APP_ID + META_APP_SECRET — Facebook / Instagram Graph API app credentials.
#   Obtain at https://developers.facebook.com → Your Apps.
#   META_APP_SECRET is already present above (shared with webhook verification);
#   META_APP_ID is the additional var needed for the social planner gate.
# INERT for the network when either var is absent.
META_APP_ID=
# ── LinkedIn ───────────────────────────────────────────────────────────────
# Social app (Sign In with LinkedIn + Share on LinkedIn + Community Management).
# Personal-feed publishing is self-serve; Company-Page publishing + comments
# need Community Management API review. Redirect URI to register:
#   ${PUBLIC_BASE_URL}/api/marketing/social/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# REST API version (YYYYMM). Bump as LinkedIn sunsets versions.
LINKEDIN_API_VERSION=202406
# Ads app (Marketing Developer Platform / Advertising API — partner-reviewed).
# Distinct app from the social one above. Powers ads reporting. Redirect URI:
#   ${PUBLIC_BASE_URL}/api/marketing/ads/oauth/linkedin/callback
LINKEDIN_ADS_CLIENT_ID=
LINKEDIN_ADS_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY + TIKTOK_CLIENT_SECRET — TikTok Content Posting API app.
#   Obtain at https://developers.tiktok.com → Manage apps. INERT when absent.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# TikTok for Business (Marketing API + Business Messaging). Distinct developer
# app from the consumer TIKTOK_CLIENT_KEY/SECRET above. Powers ads reporting and
# (allowlist-gated) DM. Register redirect URI:
#   ${API_URL}/api/marketing/ads/oauth/tiktok/callback
TIKTOK_BUSINESS_APP_ID=
TIKTOK_BUSINESS_APP_SECRET=
# Optional: override the API base (e.g. a sandbox host) — defaults to v1.3 prod.
# TIKTOK_BUSINESS_API_BASE_URL=
# INSTAGRAM_APP_ID + INSTAGRAM_APP_SECRET — "Instagram API with Instagram Login"
#   (the DIRECT flow: the user logs in at instagram.com, NOT via a Facebook
#   Page). DISTINCT from META_APP_ID/SECRET. Obtain at
#   https://developers.facebook.com → your app → "API setup with Instagram
#   login" → Instagram app ID / Instagram app secret. Register the redirect URI
#   ${PUBLIC_BASE_URL}/api/marketing/social/oauth/instagram_login/callback.
#   INERT for the network when either var is absent.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
#
# ── One-click OAuth connect (Social Planner) ──────────────────────────────
# The "Connect" buttons run an OAuth redirect flow. For each provider, register
# this redirect URI in the developer app (replace <API_URL> with the value of
# API_URL above, e.g. https://marketing.example.com/api):
#   Facebook : <API_URL>/marketing/social/oauth/facebook/callback
#   Instagram: <API_URL>/marketing/social/oauth/instagram/callback
#   Instagram (Login): <API_URL>/marketing/social/oauth/instagram_login/callback
#   LinkedIn : <API_URL>/marketing/social/oauth/linkedin/callback
#   TikTok   : <API_URL>/marketing/social/oauth/tiktok/callback
# After consent the user is redirected to APP_URL/social?connect=<id> to pick
# which page(s)/account(s) to connect. Publishing scopes (pages_manage_posts,
# instagram_content_publish, w_organization_social, video.publish) require each
# provider's App Review / audit before non-test users can authorize.

# ── Observability ─────────────────────────────────────────────────────────
# Log output shape. 'json' = structured one-line JSON (default in production,
# correlated with X-Request-ID); 'pretty' = human-readable (default in a dev
# TTY). Leave unset to use the per-environment default.
LOG_FORMAT=
# Bearer token gating GET /api/metrics (Prometheus scrape). When set, scrapers
# must send `Authorization: Bearer <token>` or `x-metrics-token`. When unset the
# endpoint is open — production should set this AND restrict /api/metrics at the
# edge (the public vhost must not proxy it). Liveness/readiness at /api/health.
METRICS_SCRAPE_TOKEN=
# Overrides the `replica` label stamped on all metrics (defaults to HOSTNAME).
# METRICS_REPLICA=

# ── Optional ──────────────────────────────────────────────────────────────
# Netgsm click-to-dial sales line (informational; telephony works without it).
# NETGSM_SALES_LINE=
# NOTE: NetGSM *SMS* credentials are NOT env vars. usercode / password (API
# sub-user) / msgheader (İYS-approved sender header) are entered per SMS channel
# in the Channels settings UI and sealed in the DB — not read from the environment.
# Days dispatched outbox rows are retained before pruning (default 14).
# OUTBOX_RETENTION_DAYS=14
# Express trust-proxy hops (default 1).
# TRUST_PROXY=1
# Opt-in Prisma query logging (never honored in production).
# PRISMA_LOG_QUERIES=false

# ── Epic-13 / post-program features (ALL inert until set) ─────────────────────
# Every block below is dormant by default; the feature activates only when its
# var(s) are set. Some ALSO need an external account or infra (noted inline).
#
# Prospecting audit — a free Google PageSpeed Insights API key. request() returns
# 503 until set; on-page SEO/HTTPS checks also gate on it.
# PAGESPEED_API_KEY=
#
# PayTR PSP (platform billing) — merchant creds + LIVE-mode flag. ⚠ PAYTR_TEST_MODE
# defaults to "1" (TEST sandbox); FLIP TO "0" to collect real money, else customers
# complete "successful" checkouts that never settle. (Per-workspace INVOICE PayTR
# creds are entered in the UI + sealed in the DB — not env.)
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=1
#
# iyzico PSP (per-workspace INVOICE collection) — apiKey/secretKey are entered in
# the UI + sealed in the DB, not env. IYZICO_BASE_URL only overrides the API host:
# leave unset for production (https://api.iyzipay.com); set to the sandbox host
# (https://sandbox-api.iyzipay.com) to test without collecting real money.
# IYZICO_BASE_URL=
#
# Call-recording sync — NetGSM CDR/recording download base URL. ⚠ External blocker:
# NetGSM must first expose a recording API; cannot be enabled until then.
# NETGSM_RECORDING_BASE_URL=
#
# ── Voice AI (all inert until set) ────────────────────────────────────────────
# Speech-to-text for post-call analysis + (optional) copilot. Needs a NetGSM
# "Görüşme Kaydı" add-on + NETGSM_RECORDING_BASE_URL above for recordings to exist.
# STT_PROVIDER=deepgram   # deepgram | openai
# STT_API_KEY=
# Custom-LLM bridge: the shared bearer secret an AI voice partner (VAPI / Retell /
# ElevenLabs) sends so its "LLM" is our Claude + knowledge base. Needs the NetGSM
# SIP Trunk + Yapay Zeka add-ons to route real calls to the partner.
# VOICE_AI_BRIDGE_SECRET=
# NetGSM "Özel API (Custom)" inbound IVR webhook token (TTS robot). Needs the paid
# "Özel API (Custom)" Netsantral integration activated.
# NETGSM_IVR_TOKEN=
#
# Sending domains / DKIM — the transactional ESP that actually sends from a tenant
# domain (the platform's shared SMTP is not one). Until set, mail keeps the platform
# From. SPF include is the platform host tenants add to their SPF record.
# SENDING_DOMAIN_ESP=
# SENDING_DOMAIN_SPF_INCLUDE=spf.platform.example
#
# Custom-domain white-label — Host-header middleware is a pure no-op until enabled.
# ⚠ Also needs wildcard ingress + on-demand ACME TLS the app cannot provision.
# CUSTOM_DOMAINS_ENABLED=
# CUSTOM_DOMAIN_CNAME_TARGET=ingress.platform.example
#
# Review-sync (Google Business / Facebook) — OAuth app creds; per-source page/location
# tokens are entered in the UI. NOTE the Google name collision: review-sync + GMB read
# GOOGLE_CLIENT_ID/_SECRET, while Calendar reads GOOGLE_OAUTH_CLIENT_ID/_SECRET — set
# whichever the feature you want needs (ideally set both pairs to the same app).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# ESP delivery-feedback (bounce/complaint suppression) — HMAC secret for the
# /api/public/esp/feedback webhook. 401 until set. Point your ESP's event webhook here.
# ESP_FEEDBACK_SECRET=
#
# Tier-2 email verification (real mailbox check, e.g. ZeroBounce/NeverBounce/Kickbox).
# Both required; falls back to syntax+MX (tier-1) until set.
# EMAIL_VERIFY_API_URL=
# EMAIL_VERIFY_API_KEY=
#
# OAuth dev-app creds for the social/calendar connect flows (provider apps required):
# MS_OAUTH_CLIENT_ID=          # Outlook/O365 calendar — unlocks OAuth connect AND
# MS_OAUTH_CLIENT_SECRET=      #   2-way Graph sync (push /me/events, calendarView
#                              #   delta pull, change-notification subscriptions).
# MS_OAUTH_REDIRECT_URI=       #   Optional; derived from MARKETING_PUBLIC_URL when
#                              #   unset. The Graph webhook (subscription target)
#                              #   needs MARKETING_PUBLIC_URL to be a public https
#                              #   URL — without it, sync falls back to manual/button.
# X_CLIENT_ID=                 # X/Twitter publishing
# X_CLIENT_SECRET=
# PINTEREST_APP_ID=            # Pinterest publishing
# PINTEREST_APP_SECRET=
