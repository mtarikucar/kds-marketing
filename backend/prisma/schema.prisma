/// Social account connected to a workspace (env-gated per-network publish).
/// accessToken is SEALED (secret-box v1:...) — never returned raw in API responses.
model SocialAccount {
  id             String    @id @default(uuid())
  workspaceId    String
  network        String // FACEBOOK | INSTAGRAM | LINKEDIN
  externalId     String // provider page/profile id
  displayName    String
  accessToken    String    @db.Text // SEALED — never returned raw
  tokenExpiresAt DateTime?
  refreshToken   String?   @db.Text // SEALED — provider refresh token (LinkedIn/TikTok)
  accountType    String? // PAGE | IG_BUSINESS | LI_PERSON | LI_ORG | TIKTOK
  connectedVia   String    @default("MANUAL") // MANUAL | OAUTH
  lastError      String? // e.g. 'reauth_required' when token refresh fails
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())

  targets SocialPostTarget[]

  @@unique([workspaceId, network, externalId])
  @@index([workspaceId, network])
  @@map("social_accounts")
}

/// Short-lived handoff between the OAuth callback and the user's account-pick
/// step. The callback stashes the provider token + the list of connectable
/// assets here (sealed); the user then picks which to turn into SocialAccounts.
model PendingSocialConnection {
  id          String   @id @default(uuid())
  workspaceId String
  network     String
  payload     String   @db.Text // SEALED JSON { token, refreshToken?, expiresAt?, assets:[...] }
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([workspaceId])
  @@map("pending_social_connections")
}

/// A social post authored in the planner (may fan out to multiple networks).
model SocialPost {
  id               String    @id @default(uuid())
  workspaceId      String
  content          String    @db.Text
  mediaUrls        String[]
  /// Free-form publish options: per-target formats ({accountId: FEED|REEL|STORY}),
  /// uploaded media descriptors ([{url,key,mime}] for R2 cleanup), mediaDeletedAt,
  /// and per-post network-specific controls. For TikTok:
  /// { tiktok?: { privacyLevel?: string, disableComment?: boolean,
  ///   disableDuet?: boolean, disableStitch?: boolean, mediaType?: 'VIDEO'|'PHOTO',
  ///   coverIndex?: number } }
  options          Json?
  status           String    @default("DRAFT") // DRAFT|SCHEDULED|PUBLISHING|PUBLISHED|FAILED
  scheduledAt      DateTime?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  /// AI Social Content Studio — set when a post originates from a SocialCampaign.
  socialCampaignId String?
  campaignItemId   String?

  targets SocialPostTarget[]

  @@index([workspaceId, status])
  @@index([socialCampaignId])
  @@map("social_posts")
}

/// A single per-network publish target for a SocialPost.
model SocialPostTarget {
  id              String        @id @default(uuid())
  workspaceId     String
  postId          String
  post            SocialPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccountId String
  account         SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Restrict)
  network         String // FACEBOOK | INSTAGRAM | LINKEDIN
  status          String        @default("PENDING") // PENDING|PUBLISHED|FAILED
  externalPostId  String?
  error           String?

  metrics SocialPostMetric[]

  @@index([workspaceId, postId])
  @@index([workspaceId, status])
  @@map("social_post_targets")
}

/// Organic performance of a published social post, pulled back per network per
/// UTC day (idempotent upsert on targetId+date — a re-pull never duplicates).
/// The organic mirror of AdMetric: the Performance Loop reads these to attribute
/// reach/engagement/leads to a specific piece of content. Provider-reported
/// counts; `leads` is Jeeta-side first-party (joined via LeadAttribution).
model SocialPostMetric {
  id          String           @id @default(uuid())
  workspaceId String
  targetId    String
  target      SocialPostTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  date        DateTime         @db.Date // UTC day
  impressions Int              @default(0)
  reach       Int              @default(0)
  engagements Int              @default(0)
  likes       Int              @default(0)
  comments    Int              @default(0)
  shares      Int              @default(0)
  saves       Int              @default(0)
  clicks      Int              @default(0)
  videoViews  Int              @default(0)
  leads       Int              @default(0)
  raw         Json?
  pulledAt    DateTime         @default(now())

  @@unique([targetId, date])
  @@index([workspaceId, date])
  @@map("social_post_metrics")
}

/// One Brand Kit per workspace — logo, palette, tone, 3–5 reference images,
