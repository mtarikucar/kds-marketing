// Marketing service Prisma schema — extracted from the monorepo (Phase 5
// physical split). Contains ONLY the marketing-owned tables plus the
// outbox_events table the OutboxModule needs for durable eventing.
//
// Cross-context soft references (no FK, by design):
//   leads.convertedTenantId, commissions.tenantId / sourcePaymentId,
//   lead_offers.planId (+ planCode/planName/planMonthlyPrice/planCurrency).
// They point at core-owned rows that live in the CORE database.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A customer organization on the platform. Every marketing-owned row hangs
/// off exactly one workspace; isolation is enforced in the service layer
/// (workspace-scoping arch spec) — workspaceId columns are plain strings
/// (no FK) to match the codebase's soft-reference style and keep workspace
/// closure a status flip, not a cascade.
model Workspace {
  id     String @id @default(uuid())
  slug   String @unique // subdomain-safe handle, e.g. "acme"
  name   String
  status String @default("ACTIVE") // ACTIVE, SUSPENDED, CLOSED

  // What this workspace sells — feeds outbound copy and (Phase E) the
  // research routine's understanding of the product.
  productName        String
  productUrl         String?
  productDescription String? @db.Text

  defaultLanguage String @default("en") // ISO 639-1
  defaultCurrency String @default("USD") // TRY | USD | EUR
  timezone        String @default("UTC")

  /// Free-shape per-workspace settings: { businessTypes: string[],
  /// emailFromName?, brandColor?, guideUrls?: {manager?, rep?} }.
  /// Jsonb so additions don't need migrations.
  settings Json?

  /// Progressive-disclosure allow-list of ACTIVATED module feature keys
  /// (string[]). NULL/absent = every entitled module is active (back-compat);
  /// when present, a toggleable module stays active only if it's also listed.
  activatedModules Json?

  /// Present ONLY on a workspace wired to a core product deployment
  /// ({ type: 'KDS_CORE', appName, appUrl }). Gates the lead→tenant
  /// provisioning flow, settlement commissions and hardware-quote intake;
  /// generic workspaces close WON leads without provisioning.
  coreIntegration Json?

  /// Epic D1 — agency / sub-account hierarchy (GoHighLevel parity).
  /// `kind` classifies the workspace in the hierarchy:
  ///   STANDALONE — a plain tenant with no parent and no children (default;
  ///                every pre-Epic-D workspace is one);
  ///   AGENCY     — owns child LOCATION workspaces it can manage;
  ///   LOCATION   — a sub-account; `parentWorkspaceId` points at its AGENCY.
  /// Modelled as a String (not a native PG enum) to match this schema's
  /// status-string convention and keep the migration a plain ADD COLUMN.
  /// Allowed values are the WorkspaceKind union in types.ts.
  kind String @default("STANDALONE")

  /// The owning AGENCY for a LOCATION sub-account; null for STANDALONE/AGENCY.
  /// Self-reference (no FK cascade, matching the soft-reference style) — the
  /// agency.service.ts cross-into-child path is the ONLY sanctioned reader and
  /// it guards every access with assertAgencyOwns (parent-ownership check).
  parentWorkspaceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([parentWorkspaceId])
  @@map("workspaces")
}

/// Platform-level operator (superadmin realm, separate JWT secret). Manages
/// workspaces, packages and manual bank-transfer activations. Deliberately
/// NOT a MarketingUser — different audience, different token type.
model PlatformOperator {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE
  failedLogins Int       @default(0)
  lockedUntil  DateTime?
  lastLogin    DateTime?

  // Same session-revocation device as MarketingUser.
  tokenVersion Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_operators")
}

model MarketingUser {
  id           String    @id @default(uuid())
  workspaceId  String
  email        String    @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  /// Netsantral extension this rep's outbound calls ring (e.g. "104"). Null = no
  /// api-dial; SalesCallService falls back to click-to-dial for this rep.
  dahili       String?
  /// AES-256-GCM sealed SIP password for this rep's dahili (in-app webphone).
  /// Served only to the owning rep over HTTPS; never returned raw.
  dahiliSecret String?
  avatar       String?
  role         String // OWNER, MANAGER, REP, SYSTEM (workspace-scoped)
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE
  lastLogin    DateTime?
  lastLoginIp  String?
  failedLogins Int       @default(0)
  lockedUntil  DateTime?

  // Public-facing referral code (e.g. "AHMET42"). Marketers share it
  // via /?ref=CODE links or word-of-mouth; the checkout flow resolves
  // it back to this row, auto-creates a WON Lead on payment success,
  // and lifetime SIGNUP/RENEWAL/UPSELL commissions accrue to this user.
  // Nullable so legacy rows backfill cleanly; @unique to keep the
  // resolver O(1).
  referralCode          String?   @unique
  referralCodeUpdatedAt DateTime?

  // Session revocation token: carried in access/refresh JWTs; bumped on
  // logout and on password change so outstanding tokens are invalidated.
  tokenVersion Int @default(0)

  // Epic F — 2FA/MFA (TOTP). Secret stored once enrollment begins; enabled only
  // after a code is verified. Backup codes are SHA-256 hashes (single-use).
  twoFactorEnabled     Boolean @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes Json?

  // Epic F — optional custom role (granular permissions). When set, its
  // permission set overrides the legacy `role` string; otherwise the legacy
  // OWNER/MANAGER/REP → permission mapping applies. Additive, non-breaking.
  customRoleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leads         Lead[]                  @relation("AssignedRep")
  activities    LeadActivity[]
  tasks         MarketingTask[]
  offers        LeadOffer[]
  commissions   Commission[]
  notifications MarketingNotification[]

  @@index([workspaceId])
  @@index([workspaceId, role])
  @@index([email])
  @@index([role])
  @@index([status])
  @@map("marketing_users")
}

model Lead {
  id            String    @id @default(uuid())
  workspaceId   String
  businessName  String
  /// Optional B2B account this contact belongs to (GHL Companies parity). Soft
  /// ref to companies.id; the flat businessName stays for display/legacy.
  companyId     String?
  contactPerson String
  phone         String?
  whatsapp      String?
  email         String?
  address       String?
  city          String?
  region        String?
  businessType  String // CAFE, RESTAURANT, BAR, PATISSERIE, FAST_FOOD, OTHER
  tableCount    Int?
  branchCount   Int?
  currentSystem String?
  source        String // INSTAGRAM, REFERRAL, FIELD_VISIT, ADS, WEBSITE, PHONE, OTHER
  status        String    @default("NEW") // NEW, CONTACTED, NOT_REACHABLE, MEETING_DONE, DEMO_SCHEDULED, OFFER_SENT, WAITING, WON, LOST
  lostReason    String?
  notes         String?   @db.Text
  nextFollowUp  DateTime?
  priority      String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  // Dedup key from the research routine; uniqueness is per-workspace so two
  // customers may independently surface the same business.
  externalRef   String?

  /// AI fit/value score (0-100) + reason from the lead-scoring routine. Advisory;
  /// separate from rep-set priority/status. scoredAt null = not yet scored.
  aiScore       Int?
  aiScoreReason String?   @db.Text
  scoredAt      DateTime?

  // Assigned sales rep
  assignedToId String?
  assignedTo   MarketingUser? @relation("AssignedRep", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Conversion tracking
  // Step-F decoupling: soft (no-FK) reference to the core-owned tenant. @unique
  // is a marketing-local invariant (one lead per converted tenant), kept.
  convertedTenantId String?   @unique
  convertedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  activities  LeadActivity[]
  tasks       MarketingTask[]
  offers      LeadOffer[]
  commissions Commission[]     @relation("CommissionLead")
  tags        LeadTag[]
  attribution LeadAttribution?

  // v3.0.1 round-4 — hardware "Teklif Al" leads (source=HARDWARE_QUOTE)
  // capture (a) the requesting tenant via soft-FK string and (b) a
  // frozen snapshot of the catalog row + requested qty at request time.
  // Snapshot is intentionally schema-less JSON so future tier requirements
  // (delivery window, install type, etc.) extend without a migration.
  // `originTenantId` stays a String (no FK) — core's tenant table lives in
  // another database entirely.
  productSnapshot Json?
  originTenantId  String?

  // Phase F P2 — per-channel marketing opt-out. Campaigns AND the Conversation
  // AI engine check these before sending. Default false = opted-in.
  emailOptOut         Boolean   @default(false)
  /// List-hygiene tier-1 (GHL parity): syntax+MX verification result, set at
  /// ingest. UNKNOWN | VALID | INVALID | RISKY. INVALID is excluded from email
  /// campaign audiences.
  emailVerifiedStatus String    @default("UNKNOWN")
  /// Stamped when the ESP reports a hard bounce/complaint for this email — the
  /// lead is then suppressed from email campaigns (with emailOptOut).
  emailBouncedAt      DateTime?
  smsOptOut           Boolean   @default(false)
  waOptOut            Boolean   @default(false)

  // Epic A1 — workspace-defined custom fields. Shape is { "<defKey>": value };
  // values are validated/coerced against CustomFieldDef by CustomFieldsService
  // before write. GIN-indexed (jsonb_path_ops) for segment/audience filtering.
  customFields Json @default("{}")

  // Epic A4 — duplicate detection + merge. Normalized match keys are maintained
  // on every write; `mergedIntoId` tombstones a lead folded into a canonical one
  // (kept, not deleted, so old links still resolve).
  phoneNormalized String?
  emailNormalized String?
  mergedIntoId    String?
  mergedAt        DateTime?
  // Inbox productivity (GHL parity): soft-delete via bulk actions. A deleted
  // lead is hidden from the pipeline list/count (like a merge tombstone) but
  // kept for audit; a direct GET /:id still resolves it.
  deletedAt       DateTime?

  @@unique([workspaceId, externalRef])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, companyId])
  @@index([assignedToId])
  @@index([status])
  @@index([city])
  @@index([source])
  @@index([businessType])
  @@index([createdAt])
  @@index([nextFollowUp])
  @@index([priority])
  @@index([assignedToId, status])
  @@index([workspaceId, assignedToId])
  @@index([status, createdAt])
  @@index([originTenantId])
  @@index([workspaceId, scoredAt])
  @@index([customFields], type: Gin, map: "leads_customFields_gin")
  @@index([workspaceId, phoneNormalized])
  @@index([workspaceId, emailNormalized])
  @@index([mergedIntoId])
  @@map("leads")
}

/// First-touch marketing attribution for a Lead (1:1), captured at ingest from
/// an inbound conversation, a site form, or an ad click. Soft (no-FK) content
/// references so a deleted post/campaign/ad never blocks a lead. The Faz 5/7
/// Performance Loop joins spend↔content↔revenue through these keys.
model LeadAttribution {
  id                     String   @id @default(uuid())
  workspaceId            String
  leadId                 String   @unique
  lead                   Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // Marketing params captured verbatim from the landing URL / referral payload.
  utmSource              String?
  utmMedium              String?
  utmCampaign            String?
  utmContent             String?
  utmTerm                String?
  // Platform click identifiers.
  clickId                String?
  clickIdType            String? // FBCLID | GCLID | TTCLID | LICLID | OTHER
  // Click-to-WhatsApp referral (Meta CTWA) — ties a WA conversation to its ad.
  ctwaClid               String?
  landingUrl             String?  @db.Text
  referrerUrl            String?  @db.Text
  // Soft content / campaign / ad references (no FK — content may be deleted).
  sourceSocialPostId     String?
  sourceCampaignItemId   String?
  sourceSocialCampaignId String?
  sourceAdCampaignId     String?
  sourceAdCreativeId     String?
  raw                    Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([workspaceId, sourceSocialPostId])
  @@index([workspaceId, sourceAdCampaignId])
  @@index([workspaceId, ctwaClid])
  @@index([workspaceId, clickId])
  @@map("lead_attributions")
}

/// Epic A1 — workspace-scoped typed custom-field definitions. Values live in
/// Lead.customFields (JSONB). `key` + `type` are immutable after creation (values
/// are keyed by `key`); deleting = archive (values retained). `entity` is
/// enum-ready (LEAD today; CONTACT|OPPORTUNITY later) but only LEAD is wired.
model CustomFieldDef {
  id          String   @id @default(uuid())
  workspaceId String
  entity      String   @default("LEAD") // LEAD (enum-ready: CONTACT | OPPORTUNITY)
  key         String // slug, immutable, unique per (workspace, entity)
  label       String
  type        String // TEXT|TEXTAREA|NUMBER|DATE|DATETIME|BOOL|SELECT|MULTISELECT|URL|PHONE|EMAIL
  options     Json? // [{ value, label }] for SELECT/MULTISELECT
  required    Boolean  @default(false)
  position    Int      @default(0)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, entity, key])
  @@index([workspaceId, entity, archived])
  @@map("custom_field_defs")
}

/// A B2B account/company (GoHighLevel Companies parity). Contacts (Lead.companyId)
/// belong to a company; the company rolls up their opportunities + conversations.
/// `customFields` holds values for the workspace's COMPANY CustomFieldDefs (same
/// pattern as leads). No FK — soft `workspaceId` scoping like the rest of CRM.
model Company {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String
  domain       String?
  phone        String?
  email        String?
  address      String?
  city         String?
  notes        String?  @db.Text
  customFields Json?
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workspaceId, archived])
  @@map("companies")
}

/// Custom Objects (GoHighLevel parity) — a workspace-defined record type beyond
/// the built-in Contact (e.g. Property, Vehicle, Policy). Its fields reuse
/// CustomFieldDef rows namespaced by `entity = "OBJ:<key>"`, so the whole
/// custom-field type/validation machinery is shared. `primaryField` names the
/// field whose value is denormalized into CustomObjectRecord.displayName.
/// DEPRECATED (2026-07 system trim): the custom-objects feature was removed — no UI or
/// API serves this model anymore. The table + any tenant data are RETAINED
/// on purpose (no destructive migration); drop in a later cleanup once the
/// owner confirms zero production usage.
model CustomObjectDef {
  id            String   @id @default(uuid())
  workspaceId   String
  key           String // slug, immutable, unique per workspace
  labelSingular String
  labelPlural   String
  primaryField  String   @default("name") // field key used as the record's display name
  description   String?
  icon          String?
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  records CustomObjectRecord[]

  @@unique([workspaceId, key])
  @@index([workspaceId, archived])
  @@map("custom_object_defs")
}

/// One instance of a custom object. Field values live in `values` (JSONB,
/// validated against the object's CustomFieldDefs); `displayName` is denormalized
/// from the primary field for cheap list/search. Cascade-deleted with its def.
/// DEPRECATED (2026-07 system trim): the custom-objects feature was removed — no UI or
/// API serves this model anymore. The table + any tenant data are RETAINED
/// on purpose (no destructive migration); drop in a later cleanup once the
/// owner confirms zero production usage.
model CustomObjectRecord {
  id          String          @id @default(uuid())
  workspaceId String
  objectDefId String
  objectDef   CustomObjectDef @relation(fields: [objectDefId], references: [id], onDelete: Cascade)
  values      Json            @default("{}")
  displayName String          @default("")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  links CustomObjectLink[]

  @@index([workspaceId, objectDefId])
  @@index([workspaceId, objectDefId, displayName])
  @@map("custom_object_records")
}

/// Association between a custom-object record and a Contact (Lead, soft ref).
/// The (record, lead) pair is unique so linking is idempotent. Cascade-deleted
/// with its record; lead deletion is reconciled by the records service.
/// DEPRECATED (2026-07 system trim): the custom-objects feature was removed — no UI or
/// API serves this model anymore. The table + any tenant data are RETAINED
/// on purpose (no destructive migration); drop in a later cleanup once the
/// owner confirms zero production usage.
model CustomObjectLink {
  id          String             @id @default(uuid())
  workspaceId String
  recordId    String
  record      CustomObjectRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  leadId      String // associated Contact (soft ref to Lead — no FK, multi-tenant pattern)
  label       String? // e.g. "owner", "primary contact"
  createdAt   DateTime           @default(now())

  @@unique([recordId, leadId])
  @@index([workspaceId, leadId])
  @@index([workspaceId, recordId])
  @@map("custom_object_links")
}

/// Epic A2 — workspace-scoped lead tag taxonomy. `nameLower` is the
/// service-maintained case-insensitive uniqueness key (assign-by-name is
/// idempotent regardless of casing). Tag↔Lead is the LeadTag join table.
model Tag {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  nameLower   String
  color       String? // hex, optional
  createdAt   DateTime @default(now())

  leadTags LeadTag[]

  @@unique([workspaceId, nameLower])
  @@index([workspaceId])
  @@map("tags")
}

/// Epic A2 — Tag↔Lead membership. Composite PK makes assignment idempotent.
model LeadTag {
  leadId       String
  tagId        String
  assignedAt   DateTime @default(now())
  assignedById String?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@index([tagId])
  @@map("lead_tags")
}

/// Epic A3 — a saved, reusable lead audience. `definition` is a typed predicate
/// tree (group: {op, children[]}; leaf: {field, cmp, value}) over native Lead
/// columns, `cf:<key>` custom fields, and `tag` membership. DYNAMIC = evaluated
/// live by SegmentCompilerService; the same compiler resolves campaign audiences.
model Segment {
  id              String    @id @default(uuid())
  workspaceId     String
  name            String
  description     String?
  kind            String    @default("DYNAMIC") // DYNAMIC (v1)
  definition      Json
  lastCount       Int?
  lastEvaluatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([workspaceId])
  @@map("segments")
}

/// Epic A5 — a CSV lead import. Rows are parsed + stored on upload (status
/// MAPPING); on commit the mapping + dedupe policy are set and processing runs
/// in batches via the ScheduledJob queue (kind 'import.batch').
model ImportJob {
  id           String   @id @default(uuid())
  workspaceId  String
  filename     String
  status       String   @default("MAPPING") // MAPPING|RUNNING|DONE|FAILED|CANCELLED
  mapping      Json? // { csvHeader -> field } incl. cf:<key>, tags, __skip
  dedupePolicy String   @default("SKIP") // SKIP|UPDATE|CREATE
  total        Int      @default(0)
  processed    Int      @default(0)
  created      Int      @default(0)
  updated      Int      @default(0)
  skipped      Int      @default(0)
  failed       Int      @default(0)
  errors       Json? // capped sample [{ row, message }]
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rows ImportJobRow[]

  @@index([workspaceId, status])
  @@map("import_jobs")
}

model ImportJobRow {
  id          String  @id @default(uuid())
  importJobId String
  rowIndex    Int
  raw         Json
  status      String  @default("PENDING") // PENDING|DONE|SKIPPED|FAILED
  leadId      String?
  error       String?

  job ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId, status])
  @@map("import_job_rows")
}

/// Epic B1 — workspace-scoped programmatic API key. The raw key (mk_live_…) is
/// shown once on create; only the SHA-256 `keyHash` is stored and the `prefix`
/// is shown thereafter. `scopes` gates read/write on the public REST API.
model ApiKey {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  keyHash     String    @unique
  prefix      String
  scopes      Json      @default("[\"read\", \"write\"]")
  status      String    @default("ACTIVE") // ACTIVE | REVOKED
  lastUsedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([workspaceId, status])
  @@map("api_keys")
}

/// Epic B2 — an outbound webhook subscription. `events` is the JSON array of
/// domain event types this endpoint wants. `secret` is the HMAC signing key
/// (returned once on create); deliveries carry `X-Webhook-Signature`.
model WebhookEndpoint {
  id             String    @id @default(uuid())
  workspaceId    String
  url            String
  events         Json      @default("[]")
  secret         String
  description    String?
  status         String    @default("ACTIVE") // ACTIVE | DISABLED
  failureCount   Int       @default(0)
  lastDeliveryAt DateTime?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId, status])
  @@map("webhook_endpoints")
}

/// Epic B2 — one attempt-tracked delivery of a domain event to an endpoint.
model WebhookDelivery {
  id           String    @id @default(uuid())
  workspaceId  String
  endpointId   String
  eventId      String
  eventType    String
  status       String    @default("PENDING") // PENDING | SUCCESS | FAILED
  responseCode Int?
  attempts     Int       @default(0)
  error        String?
  createdAt    DateTime  @default(now())
  deliveredAt  DateTime?

  @@index([endpointId, status])
  @@index([workspaceId, createdAt])
  @@map("webhook_deliveries")
}

model LeadActivity {
  id          String  @id @default(uuid())
  type        String // CALL, VISIT, NOTE, EMAIL, WHATSAPP, STATUS_CHANGE, DEMO, MEETING
  title       String
  description String? @db.Text
  outcome     String? // POSITIVE, NEGATIVE, NEUTRAL, NO_ANSWER
  duration    Int? // Duration in minutes (for calls/visits)
  /// Structured payload for typed activity kinds. Currently used for
  /// assignment events ({ kind: 'assignment', fromUserId, fromUserName,
  /// toUserId, toUserName, bulk?, auto? }) so the timeline can render
  /// "Ahmet → Mehmet" without re-parsing the title string. Nullable so
  /// every legacy STATUS_CHANGE row stays valid without a backfill.
  metadata    Json?

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   MarketingUser @relation(fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([createdById])
  @@index([createdAt])
  @@index([type])
  @@map("lead_activities")
}

model MarketingTask {
  id          String    @id @default(uuid())
  workspaceId String
  title       String
  description String?
  type        String // CALL, VISIT, DEMO, FOLLOW_UP, MEETING, OTHER
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate     DateTime
  completedAt DateTime?

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  assignedToId String
  // Restrict (not Cascade): hard-deleting a rep must not silently delete their
  // open work items — reassign first. (Reps are deactivated, not row-deleted.)
  assignedTo   MarketingUser @relation(fields: [assignedToId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([assignedToId])
  @@index([leadId])
  @@index([dueDate])
  @@index([status])
  @@index([assignedToId, status])
  @@index([dueDate, status])
  @@map("marketing_tasks")
}

model LeadOffer {
  id          String  @id @default(uuid())
  workspaceId String
  planId      String?

  /// Step-E plan snapshot, captured at offer-create time via the provisioning
  /// port (CoreProvisioningPort.describePlan) so the offer stays self-contained
  /// once the plan FK is dropped (Step F) and the plan moves to a separate DB.
  /// Soft data — nullable; planId stays the canonical (soft) reference.
  planCode         String?
  planName         String?
  planMonthlyPrice Decimal? @db.Decimal(10, 2)
  planCurrency     String?

  customPrice Decimal?  @db.Decimal(10, 2)
  // v2.8.97 — was Decimal(5, 2) which capped the discount at 999.99
  // TRY. Sales reps offering a four-digit lira discount on enterprise
  // tiers would have hit a silent precision overflow. Aligned with
  // every other money column in the schema (Decimal(10, 2)).
  discount    Decimal?  @db.Decimal(10, 2)
  trialDays   Int?
  notes       String?   @db.Text
  status      String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  validUntil  DateTime?
  sentAt      DateTime?
  respondedAt DateTime?

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   MarketingUser @relation(fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([leadId])
  @@index([createdById])
  @@index([status])
  @@index([leadId, status])
  @@map("lead_offers")
}

model Commission {
  id          String  @id @default(uuid())
  workspaceId String
  amount      Decimal @db.Decimal(10, 2)
  type        String // SIGNUP, RENEWAL, UPSELL
  status      String  @default("PENDING") // PENDING, APPROVED, PAID
  period      String // "2026-04" (YYYY-MM format)
  // Step-F decoupling: soft (no-FK) reference to the core-owned tenant.
  tenantId    String?
  leadId      String?
  // Restrict (not SetNull): a commission is a money record — its link to the
  // deal that earned it must not be silently severed by a lead deletion.
  lead        Lead?   @relation("CommissionLead", fields: [leadId], references: [id], onDelete: Restrict)
  notes       String? @db.Text

  marketingUserId String
  marketingUser   MarketingUser @relation(fields: [marketingUserId], references: [id], onDelete: Restrict)

  approvedAt   DateTime?
  approvedById String? // MarketingUser.id of the manager who approved
  paidAt       DateTime?
  paidById     String? // MarketingUser.id of the manager who marked paid
  /// Append-only state-transition log: every approve/pay/amount edit
  /// pushes one entry `{ at, actorId, action, prev?, next? }`. JSON
  /// rather than a separate table because the volume is low (a few
  /// rows per commission lifetime) and we never need to join on it.
  auditLog     Json?

  /// Step-C decoupling: the SubscriptionPayment.id that triggered this credit.
  /// Set by the marketing SettlementCommissionConsumer so RENEWAL/UPSELL credits
  /// are exactly-once under event replay. A partial-unique on
  /// (sourcePaymentId, type) — WHERE sourcePaymentId IS NOT NULL — enforces it
  /// at the DB; declared in raw SQL since Prisma can't express partial uniques.
  /// Soft reference (no FK): the payment lives in the core context.
  sourcePaymentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, period])
  @@index([marketingUserId])
  @@index([tenantId])
  @@index([leadId])
  @@index([period])
  @@index([status])
  @@index([period, status])
  @@index([sourcePaymentId])
  @@map("commissions")
}

model MarketingNotification {
  id          String  @id @default(uuid())
  workspaceId String
  type        String // FOLLOW_UP_REMINDER, DEMO_REMINDER, INACTIVE_LEAD, OFFER_EXPIRING, TASK_DUE
  title       String
  message     String
  isRead      Boolean @default(false)
  metadata    Json?

  userId String
  user   MarketingUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("marketing_notifications")
}

/// Per-workspace row controlling how newly-created leads are auto-assigned
/// to sales reps. A missing row (or strategy=DISABLED) means manual
/// assignment only — managers dispatch leads themselves. ROUND_ROBIN
/// rotates through ACTIVE REP users in stable createdAt order,
/// using `lastAssignedToId` as a cursor. LEAST_LOADED picks the rep
/// with the fewest open (non-WON/LOST) leads at the time of the new
/// lead. One row per workspace; created with strategy=DISABLED on signup.
model MarketingDistributionConfig {
  id               String   @id @default(uuid())
  workspaceId      String   @unique
  strategy         String   @default("DISABLED") // DISABLED, ROUND_ROBIN, LEAST_LOADED
  lastAssignedToId String?
  updatedById      String?
  updatedAt        DateTime @updatedAt

  @@map("marketing_distribution_config")
}

/// Phase-2 telephony: a single-line sales-call log over the company Netgsm line.
/// Click-to-dial + manual outcome logging behind the TelephonyProvider
/// abstraction. marketingUserId / leadId are soft references to the
/// marketing-owned MarketingUser / Lead (no FK — keeps the model portable and
/// avoids back-relations). externalCallId / durationSec / recordingUrl are the
/// seams a future Netgsm API/webhook provider fills.
model SalesCall {
  id                 String    @id @default(uuid())
  workspaceId        String
  marketingUserId    String
  leadId             String?
  direction          String    @default("OUTBOUND") // OUTBOUND, INBOUND
  toPhone            String
  providerId         String // 'netgsm-lite', ...
  status             String    @default("INITIATED") // INITIATED, CONNECTED, NO_ANSWER, BUSY, FAILED, CANCELLED
  externalCallId     String?
  durationSec        Int?
  /// Budget Autopilot: billable duration + real per-minute cost (ChannelTariff
  /// VOICE_MINUTE), debited to SpendLedger. Null = not yet settled.
  billableSeconds    Int?
  costAmount         Decimal?  @db.Decimal(14, 4)
  recordingUrl       String?
  // Epic 13 call-recording: watermark so the hourly sweep pushes a tried call to
  // the back of the queue (a CONNECTED call with no recording yet, or never), and
  // never re-burns the same dead rows at the front (mirrors AdAccount.lastPulledAt).
  recordingCheckedAt DateTime?
  notes              String?   @db.Text
  startedAt          DateTime  @default(now())
  endedAt            DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([workspaceId])
  @@index([marketingUserId, startedAt(sort: Desc)])
  @@index([leadId])
  @@index([status])
  @@map("sales_calls")
}

/// Voice-AI Phase 1 — post-call analysis: a SalesCall recording is transcribed
/// (STT) then run through Claude for a structured summary/sentiment/score. One
/// row per SalesCall (relation-free, keyed by salesCallId @unique); produced by
/// the analysis cron sweep or the manual-run endpoint. Inert until STT + Claude
/// are configured (NetGSM Görüşme Kaydı recordings + STT key).
model CallAnalysis {
  id          String   @id @default(uuid())
  workspaceId String
  salesCallId String   @unique
  transcript  String   @db.Text
  language    String?
  summary     String   @db.Text
  sentiment   String? // POSITIVE | NEUTRAL | NEGATIVE
  score       Int? // 0-100 call-quality/intent score
  actionItems Json? // string[]
  topics      Json? // string[]
  sttProvider String?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@map("call_analyses")
}

/// Epic 11b — a PREVIEW dialer session: an ordered queue of leads a rep dials
/// one at a time (click-to-dial reusing SalesCallService, single-line). The rep
/// previews each lead, dials, logs the outcome, and the queue auto-advances.
model DialSession {
  id              String   @id @default(uuid())
  workspaceId     String
  marketingUserId String
  status          String   @default("ACTIVE") // ACTIVE | DONE | CANCELLED
  currentIndex    Int      @default(0)
  total           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items DialSessionItem[]

  @@index([workspaceId, marketingUserId])
  @@map("dial_sessions")
}

/// One lead in a dial session's queue. `outcome` is set when the rep logs or
/// skips it; `callId` links to the SalesCall placed for it.
model DialSessionItem {
  id            String   @id @default(uuid())
  workspaceId   String
  dialSessionId String
  leadId        String
  position      Int
  outcome       String? // a SALES_CALL outcome, or SKIPPED
  callId        String?
  createdAt     DateTime @default(now())

  session DialSession @relation(fields: [dialSessionId], references: [id], onDelete: Cascade)

  @@unique([dialSessionId, position])
  @@index([workspaceId])
  @@map("dial_session_items")
}

/// Phase-3 installation ops (inside the marketing context). A crew is an
/// install team with a per-day job capacity used for availability checks.
model InstallationCrew {
  id            String   @id @default(uuid())
  workspaceId   String
  name          String
  active        Boolean  @default(true)
  dailyCapacity Int      @default(1)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([workspaceId])
  @@index([active])
  @@map("installation_crews")
}

/// An installation job, auto-created on lead→customer conversion
/// (marketing.lead.converted.v1) and scheduled to a crew. tenantId is a soft
/// (no-FK) reference to the core tenant; leadId/crewId are soft references to
/// the marketing-owned Lead / InstallationCrew. Site/contact are snapshotted
/// from the lead so the job never reads core tables.
model InstallationJob {
  id              String    @id @default(uuid())
  workspaceId     String
  tenantId        String
  leadId          String?
  crewId          String?
  status          String    @default("REQUESTED") // REQUESTED, SCHEDULED, IN_PROGRESS, DONE, CANCELLED, NO_SHOW
  scheduledDate   DateTime? @db.Date
  scheduledWindow String? // MORNING, AFTERNOON, FULL_DAY
  siteAddress     String?
  siteCity        String?
  contactName     String?
  contactPhone    String?
  notes           String?   @db.Text
  requestedAt     DateTime  @default(now())
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tasks InstallationTask[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([status])
  @@index([crewId, scheduledDate])
  @@index([tenantId])
  @@index([scheduledDate])
  @@map("installation_jobs")
}

/// A checklist item within an installation job.
model InstallationTask {
  id        String          @id @default(uuid())
  jobId     String
  job       InstallationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean         @default(false)
  position  Int             @default(0)
  createdAt DateTime        @default(now())

  @@index([jobId])
  @@map("installation_tasks")
}

/// Phase-4 sales targets/quotas. A manager sets a per-rep, per-period (YYYY-MM)
/// target for a metric; the performance service compares it to the actual
/// computed from marketing-owned data (won leads, commission amount, connected
/// calls). marketingUserId / setById are soft references to MarketingUser.
model SalesTarget {
  id              String   @id @default(uuid())
  workspaceId     String
  marketingUserId String
  period          String // YYYY-MM
  metric          String // WON_LEADS, COMMISSION_AMOUNT, CONNECTED_CALLS
  targetValue     Decimal  @db.Decimal(14, 2)
  setById         String
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([marketingUserId, period, metric])
  @@index([workspaceId])
  @@index([period])
  @@index([marketingUserId, period])
  @@map("sales_targets")
}

/// A research focus inside a workspace: WHO to find and HOW to pitch.
/// icpDescription is the customer-authored prompt the nightly routine
/// researches against; the workspace's daily lead quota is shared across
/// its profiles.
model ResearchProfile {
  id          String @id @default(uuid())
  workspaceId String
  name        String
  status      String @default("ACTIVE") // ACTIVE, PAUSED

  /// Customer-authored: ideal customer profile + pain signals to hunt for.
  icpDescription String  @db.Text
  /// Optional pitch angle the routine should write per-lead pitches with.
  productPitch   String? @db.Text

  /// { country?, regions?: string[], cities?: string[] } — hard geo filter.
  geo           Json?
  /// Output language for painPoint/evidence/pitch (ISO 639-1).
  language      String  @default("en")
  /// Taxonomy hints for the researcher (subset of workspace businessTypes).
  businessTypes Json?
  /// Hard exclusions, free text ("no franchises", "skip enterprises"...).
  exclusions    String? @db.Text

  lastRunAt    DateTime?
  /// { posted, created, skipped, clipped, at } from the latest routine run.
  lastRunStats Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("research_profiles")
}

/// A staged prospect-research candidate awaiting human review (the native AI
/// Research engine's suggestions queue). On ACCEPT it flows through
/// MarketingLeadsIngestService.ingest() to become a real Lead; on REJECT it is
/// dismissed. painPoint/evidence/pitch are first-class here (unlike a Lead,
/// where they'd be flattened into notes).
model ResearchCandidate {
  id            String    @id @default(uuid())
  workspaceId   String
  profileId     String
  agentRunId    String?
  externalRef   String
  businessName  String
  city          String?
  region        String?
  businessType  String
  phone         String?
  instagram     String?
  website       String?
  email         String?
  branchCount   Int?
  currentSystem String?
  stage         String? // GROWING | STRUGGLING | STABLE
  priority      String    @default("MEDIUM")
  painPoint     String    @db.Text
  evidence      String    @db.Text
  pitch         String    @db.Text
  score         Float?
  status        String    @default("PENDING") // PENDING | ACCEPTED | REJECTED
  leadId        String? // set when accepted + ingested
  createdAt     DateTime  @default(now())
  decidedAt     DateTime?

  @@unique([workspaceId, profileId, externalRef])
  @@index([workspaceId, status, createdAt])
  @@map("research_candidates")
}

/// Opt-in content-generation profile (one+ per workspace) driving the weekly
/// content-pack routine. Mirrors ResearchProfile.
model ContentProfile {
  id          String @id @default(uuid())
  workspaceId String
  name        String
  status      String @default("ACTIVE") // ACTIVE | PAUSED

  /// Customer-authored themes/topics to write about.
  themes   String  @db.Text
  /// Optional voice/tone guidance.
  voice    String? @db.Text
  /// Per-channel piece counts, e.g. { "social": 5, "email": 2, "sms": 1 }.
  counts   Json
  /// Output language (ISO 639-1).
  language String  @default("en")

  lastRunAt    DateTime?
  /// { social, email, sms, at } from the latest routine run.
  lastRunStats Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("content_profiles")
}

/// A single AI-generated copy draft (social/email/sms) produced by the
/// content-pack routine. Draft-only: never auto-sent. Humans review/use it.
model ContentDraft {
  id               String  @id @default(uuid())
  workspaceId      String
  contentProfileId String?
  channel          String // social | email | sms
  subject          String? @db.Text
  body             String  @db.Text
  status           String  @default("DRAFT") // DRAFT | USED | DISCARDED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("content_drafts")
}

/// A weekly AI-written insights digest for a workspace: a KPI snapshot plus a
/// narrative + recommendations. Produced by the insight-digest routine.
model InsightDigest {
  id          String   @id @default(uuid())
  workspaceId String
  periodStart DateTime
  periodEnd   DateTime
  /// KPI snapshot, e.g. { leadsNew, leadsTotal, reviewsNew, avgRating, campaignsSent }.
  metrics     Json
  body        String   @db.Text

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@map("insight_digests")
}

/// Per-workspace ingest credential. Only the sha256 hash is stored; the raw
/// token (mkt_live_<hex>) is shown exactly once at mint time. Replaces the
/// global MARKETING_INGEST_TOKEN env.
model IngestToken {
  id          String    @id @default(uuid())
  workspaceId String
  tokenHash   String    @unique
  /// First characters of the raw token so the UI can identify it.
  tokenPrefix String
  label       String
  status      String    @default("ACTIVE") // ACTIVE, REVOKED
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([workspaceId])
  @@map("ingest_tokens")
}

/// Daily usage counters (UTC periodKey YYYY-MM-DD). The ingest path
/// reserves/settles `leads.ingested` under a per-workspace advisory lock;
/// billing reads it for quota meters.
model UsageCounter {
  id          String   @id @default(uuid())
  workspaceId String
  metric      String // 'leads.ingested'
  periodKey   String // '2026-06-10'
  value       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, metric, periodKey])
  @@map("usage_counters")
}

/// A sellable package: daily lead quota + seat/profile limits + feature
/// flags + dual-currency pricing. Rows are seeded (seed-packages.ts) and
/// operator-managed; `features` keys must stay in lockstep with
/// FEATURE_KEYS in entitlements.service.ts (drift tripwire spec).
model Package {
  id                  String   @id @default(uuid())
  code                String   @unique // TRIAL, STARTER, GROWTH, SCALE, OPERATOR
  name                String
  description         String?
  dailyLeadQuota      Int // -1 = unlimited
  maxUsers            Int
  maxResearchProfiles Int
  features            Json // FEATURE_KEYS (19): autoAssign, telephony, installations, commissions, advancedReports, apiAccess, conversationAi, workflows, campaigns, funnels, reviews, askAi, agentStudio, voiceAi, invoicing, mediaGen, socialCampaigns, memberships, research
  // Numeric entitlement limits (-1 = unlimited). Keys mirror LIMIT_KEYS in
  // entitlements.service.ts (tripwire-pinned). Legacy dailyLeadQuota/maxUsers/
  // maxResearchProfiles stay as their own columns; everything new lives here
  // so adding a limit never needs a migration.
  limits              Json? // { aiCreditsMonthly, messagesMonthly, maxAgents, maxWorkflows, maxFunnels, maxKnowledgeDocs, maxCalendars }
  priceMonthlyTRY     Decimal  @db.Decimal(10, 2)
  priceMonthlyUSD     Decimal  @db.Decimal(10, 2)
  priceYearlyTRY      Decimal? @db.Decimal(10, 2)
  priceYearlyUSD      Decimal? @db.Decimal(10, 2)
  trialDays           Int      @default(0)
  isPublic            Boolean  @default(true)
  sortOrder           Int      @default(0)
  status              String   @default("ACTIVE") // ACTIVE, RETIRED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("packages")
}

/// One subscription row per workspace, mutated through its lifecycle.
model WorkspaceSubscription {
  id                 String    @id @default(uuid())
  workspaceId        String    @unique
  packageId          String
  status             String // TRIALING, ACTIVE, PAST_DUE, CANCELLED, EXPIRED
  billingCycle       String    @default("MONTHLY") // MONTHLY, YEARLY
  currency           String // TRY | USD
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  trialEndsAt        DateTime?
  provider           String? // paytr | stripe | manual
  providerRef        String? // stripe subscription id / paytr oid / bank ref

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, currentPeriodEnd])
  @@index([packageId])
  @@map("workspace_subscriptions")
}

/// Purchasable boosts on top of the package. `grants` folds into the
/// effective entitlements: limit.* keys SUM, feature.* keys OR.
model WorkspaceAddOn {
  id               String    @id @default(uuid())
  workspaceId      String
  code             String // quota_boost_10, extra_profile
  quantity         Int       @default(1)
  grants           Json // { "limit.dailyLeadQuota": 10 } | { "limit.maxResearchProfiles": 1 }
  status           String    @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED
  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("workspace_addons")
}

/// One payment attempt/instruction. providerRef + idempotencyKey are the
/// two idempotency rails: webhooks settle by providerRef, retried checkout
/// calls collapse on idempotencyKey.
model PaymentOrder {
  id             String    @id @default(uuid())
  workspaceId    String
  type           String // SUBSCRIPTION, UPGRADE, ADDON, RENEWAL
  packageId      String?
  addOnCode      String?
  quantity       Int       @default(1)
  billingCycle   String? // MONTHLY, YEARLY
  amount         Decimal   @db.Decimal(10, 2)
  currency       String // TRY | USD
  provider       String // paytr | stripe | manual
  providerRef    String?   @unique
  idempotencyKey String    @unique
  status         String    @default("PENDING") // PENDING, AWAITING_TRANSFER, SUCCEEDED, FAILED, CANCELLED, REFUNDED
  /// Raw provider payloads for audits (webhook bodies, instruction text).
  raw            Json?
  approvedById   String? // PlatformOperator.id (manual path)
  succeededAt    DateTime?
  /// Stamped when the entitlement/wallet grant SUCCEEDS (audit A1). Makes
  /// paid-but-ungranted queryable: the reconcile sweep filters grantedAt=null
  /// so its window always holds genuinely ungranted rows and can never go
  /// blind past the oldest `limit` orders.
  grantedAt      DateTime?
  failedAt       DateTime?
  failureReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@index([status, createdAt])
  @@index([status, grantedAt])
  @@map("payment_orders")
}

/// Generic delayed-work primitive — the one table behind conversation
/// follow-ups, workflow `wait` steps, campaign send batches, booking
/// reminders and invoice verify-polls. Distinct from OutboxEvent (which is
/// dispatch-asap, retention-pruned, uncancellable): jobs carry an arbitrary
/// future runAt, are cancellable, and route to per-kind handlers.
model ScheduledJob {
  id          String    @id @default(uuid())
  workspaceId String
  kind        String // 'workflow.resume' | 'conversation.followup' | 'campaign.batch' | 'booking.reminder' | 'lead.enroll_batch' | ...
  runAt       DateTime
  payload     Json
  /// Deterministic key; rescheduling collapses onto the same PENDING row
  /// (enforced by a raw partial-unique index, see the migration).
  dedupKey    String?
  status      String    @default("PENDING") // PENDING, RUNNING, DONE, FAILED, CANCELLED
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  lastError   String?
  lockedAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
  @@index([workspaceId, kind])
  @@map("scheduled_jobs")
}

/// Workspace-authored knowledge the AI agents are grounded on. v1 retrieval
/// is Postgres FTS (searchVector tsvector + GIN, language-aware via a CASE
/// whitelist trigger) — no pgvector dependency.
model KnowledgeDoc {
  id           String                   @id @default(uuid())
  workspaceId  String
  title        String
  content      String                   @db.Text
  source       String                   @default("MANUAL") // MANUAL | URL
  sourceRef    String?
  language     String                   @default("tr")
  status       String                   @default("ACTIVE") // ACTIVE | ARCHIVED
  /// Maintained by a BEFORE INSERT/UPDATE trigger (raw SQL in the migration);
  /// Prisma only needs to know the column exists.
  searchVector Unsupported("tsvector")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks KnowledgeChunk[]

  @@index([workspaceId, status])
  @@index([searchVector], type: Gin)
  @@map("knowledge_docs")
}

/// A retrievable chunk of a KnowledgeDoc for the Brand Brain (Faz 1). `embedding`
/// is a plain double-precision array (no DB extension required — pgvector is the
/// scale-up path). Hybrid retrieval prefilters by full-text on the parent doc,
/// then re-ranks candidates by cosine similarity against the query embedding,
/// returning citations back to the source doc.
model KnowledgeChunk {
  id          String       @id @default(uuid())
  workspaceId String
  docId       String
  doc         KnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  ord         Int          @default(0)
  content     String       @db.Text
  embedding   Float[] // double precision[]; empty until an embedding provider is configured
  tokens      Int?
  createdAt   DateTime     @default(now())

  @@index([workspaceId, docId, ord])
  @@map("knowledge_chunks")
}

/// An ABSTRACT format extracted from a trend (Faz 4) — NOT a copy of the video.
/// Stores the reusable structure (hook pattern, scene rhythm, pacing, caption
/// shape) plus a ToS/copy `riskScore`, so it can be remixed onto a brand rather
/// than duplicated. This "format intelligence" framing is the compliant way to
/// do trend→remix (the raw video is never stored or reproduced).
model TrendTemplate {
  id             String   @id @default(uuid())
  workspaceId    String
  sourcePlatform String // TIKTOK | INSTAGRAM | YOUTUBE
  sourceUrl      String?
  title          String?
  hookPattern    String?  @db.Text
  sceneStructure Json? // [{ scene, note }]
  pacingNote     String?  @db.Text
  captionPattern String?  @db.Text
  riskScore      Int      @default(0) // 0-100 ToS/copy risk
  extractedByAi  Boolean  @default(false)
  status         String   @default("ACTIVE") // ACTIVE | ARCHIVED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("trend_templates")
}

/// A reusable UGC persona / AI spokesperson (Faz 2). The `referenceImageUrls` +
/// `lockedSeed` are what keep the same face/outfit/identity consistent across
/// every shot of every campaign (Seedance 2.0 @reference / Higgsfield Soul ID).
/// Only synthetic or owned/consented likenesses — enforced by the compliance
/// agent, not this table.
model VideoPersona {
  id                 String   @id @default(uuid())
  workspaceId        String
  name               String
  description        String?  @db.Text
  referenceImageUrls String[]
  lockedSeed         Int?
  voiceId            String? // ElevenLabs voice id (env-gated use)
  status             String   @default("ACTIVE") // ACTIVE | ARCHIVED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("video_personas")
}

/// A one-click generated week of marketing (Faz C, Growth Studio). Holds the
/// budget analysis for the week (`budgetBreakdown`: ad-spend / content-gen /
/// conversations vs the weekly slice of the monthly growth budget). One plan per
/// (workspace, week). Items are DRAFTs until the user approves them.
/// DEPRECATED (2026-07 system trim): the WeeklyPlan feature was removed — its
/// Approve button never scheduled or published anything (dead-end). The weekly
/// CTA now provisions a real one-week SocialCampaign. Table + data retained;
/// drop in a later cleanup once zero production usage is confirmed.
model WeeklyPlan {
  id              String           @id @default(uuid())
  workspaceId     String
  weekStart       DateTime         @db.Date // Monday (UTC)
  status          String           @default("DRAFT") // DRAFT | ACTIVE | ARCHIVED
  budgetTotal     Decimal?         @db.Decimal(14, 2) // weekly budget slice
  budgetBreakdown Json? // { weeklyBudget, adSpend, contentGen, conversations, total, overBudget }
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  items           WeeklyPlanItem[]

  @@unique([workspaceId, weekStart])
  @@index([workspaceId, status])
  @@map("weekly_plans")
}

/// One draft piece of a WeeklyPlan — a social post, content idea, campaign, or
/// trend remix on a given day, with its estimated cost. Approved items flow into
/// scheduled content; `refId` links the materialized post once scheduled.
/// DEPRECATED (2026-07 system trim): the WeeklyPlan feature was removed — its
/// Approve button never scheduled or published anything (dead-end). The weekly
/// CTA now provisions a real one-week SocialCampaign. Table + data retained;
/// drop in a later cleanup once zero production usage is confirmed.
model WeeklyPlanItem {
  id          String     @id @default(uuid())
  workspaceId String
  planId      String
  plan        WeeklyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  day         DateTime   @db.Date
  type        String // SOCIAL_POST | CONTENT_IDEA | CAMPAIGN | TREND_REMIX
  channel     String? // FACEBOOK | INSTAGRAM | LINKEDIN | EMAIL | SMS | …
  title       String
  draft       String?    @db.Text
  estCost     Decimal    @default(0) @db.Decimal(14, 2)
  status      String     @default("DRAFT") // DRAFT | APPROVED | DISCARDED | SCHEDULED
  refId       String? // materialized social post id, once scheduled
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([workspaceId, planId, day])
  @@map("weekly_plan_items")
}

/// An AI agent persona (Agent Studio): tone/goals/guardrails + which KB docs
/// it can cite + which channels it answers on + lead-capture + human-handoff
/// rules + follow-up policy. Conversation AI, Content AI and Voice AI all
/// run grounded on one of these.
model AgentProfile {
  id                      String  @id @default(uuid())
  workspaceId             String
  name                    String
  status                  String  @default("ACTIVE") // ACTIVE | PAUSED
  persona                 String  @db.Text
  tone                    String?
  goals                   String? @db.Text
  guardrails              String? @db.Text
  language                String  @default("tr")
  /// JSON arrays / objects: channels (Channel ids), kbDocIds, captureFields
  /// (['email','city',...]), handoffRules ({keywords:[], outsideBusinessHours}),
  /// followup ({enabled, afterHours, maxFollowups}).
  channels                Json?
  kbDocIds                Json?
  captureFields           Json?
  handoffRules            Json?
  followup                Json?
  bookingCalendarId       String?
  maxRepliesPerConvoDaily Int     @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("agent_profiles")
}

/// A connected customer-messaging channel (web-chat, WhatsApp Cloud, NetGSM
/// SMS, Instagram, Messenger). Secret credentials are AES-256-GCM sealed into
/// `configSealed` (never the platform-PATCHable Workspace.settings); API reads
/// return them masked. `configPublic` holds non-secret settings (display name,
/// allowed web-chat origins, greeting). `externalId` is the provider-side
/// identity inbound webhooks resolve the channel by (WA phone_number_id, FB/IG
/// page id); `widgetKey` is the public web-chat embed key.
model Channel {
  id             String    @id @default(uuid())
  workspaceId    String
  type           String // WEBCHAT | WHATSAPP | SMS | INSTAGRAM | MESSENGER
  name           String
  status         String    @default("ACTIVE") // ACTIVE | DISABLED
  /// Which agent answers here (Conversation AI). Bare soft ref to AgentProfile.
  agentProfileId String?
  /// Public web-chat key embedded in widget.js (null for non-webchat).
  widgetKey      String?   @unique
  /// Provider-side identity inbound webhooks resolve by, scoped by type.
  externalId     String?
  /// AES-256-GCM sealed JSON of secret creds (tokens/keys). Never returned raw.
  configSealed   String?   @db.Text
  /// Non-secret settings: { displayName, allowedOrigins[], greeting, ... }.
  configPublic   Json?
  lastVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, type])
  @@index([workspaceId, status])
  @@index([type, externalId])
  @@map("channels")
}

/// Per-workspace cloud-PBX (NetGSM Netsantral) config for api-dial outbound
/// calls. One per workspace. Secrets sealed (AES-256-GCM); reads expose only
/// which credential keys are set, never the sealed blob.
model TelephonyConfig {
  id           String   @id @default(uuid())
  workspaceId  String   @unique
  provider     String   @default("netgsm-netsantral")
  status       String   @default("ACTIVE") // ACTIVE | DISABLED
  /// Sealed JSON of { username, password } (the NetGSM API sub-user creds).
  configSealed String?  @db.Text
  /// Outbound trunk shown as the caller id (the 0850, digits only).
  trunk        String?
  /// PBX number when the account requires it (optional).
  pbxnum       String?
  /// WebRTC websocket endpoint for the in-app webphone, e.g.
  /// wss://sip5.netsantral.com:8089/ws (from the dahili edit screen).
  wssUrl       String?
  /// SIP domain/realm for AOR + targets, e.g. sip5.netsantral.com.
  sipDomain    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("telephony_configs")
}

/// Maps a channel-specific contact identity (E.164 phone / WA id / FB PSID /
/// IG-scoped id / web-chat visitor id) to a Lead, so an inbound message
/// resolves to the right person + thread. One identity value per channel.
model ContactIdentity {
  id          String @id @default(uuid())
  workspaceId String
  channelId   String
  kind        String // PHONE | WA | PSID | IGSID | WEBCHAT
  value       String // normalized identity (E.164 / wa-id / psid / visitorId)
  leadId      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, value])
  @@index([workspaceId])
  @@index([leadId])
  @@map("contact_identities")
}

/// A messaging thread with one contact on one channel. Carries the AI-control
/// state (aiPaused on human takeover; aiRepliesToday + aiRepliesDayKey enforce
/// the per-conversation daily reply cap; followupCount caps proactive nudges)
/// and the inbox view state (unreadCount, lastMessageAt, assignedToId).
model Conversation {
  id                String    @id @default(uuid())
  workspaceId       String
  channelId         String
  leadId            String
  contactIdentityId String?
  status            String    @default("OPEN") // OPEN | CLOSED | SNOOZED
  aiPaused          Boolean   @default(false)
  assignedToId      String?
  subject           String?
  unreadCount       Int       @default(0)
  followupCount     Int       @default(0)
  aiRepliesToday    Int       @default(0)
  /// UTC day (YYYY-MM-DD) the aiRepliesToday counter belongs to; the engine
  /// resets the counter when the day rolls over.
  aiRepliesDayKey   String?
  lastMessageAt     DateTime?
  lastInboundAt     DateTime?
  closedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status, lastMessageAt])
  @@index([workspaceId, assignedToId])
  @@index([channelId])
  @@index([leadId])
  @@map("conversations")
}

/// One message in a Conversation. `externalMessageId` is the provider's id,
/// uniquely indexed so a redelivered inbound webhook dedupes to one row
/// (nullable: web-chat / internal messages have none, and Postgres allows
/// many NULLs under a unique index).
model Message {
  id                String   @id @default(uuid())
  workspaceId       String
  conversationId    String
  direction         String // INBOUND | OUTBOUND
  authorType        String // CUSTOMER | AI | AGENT | SYSTEM
  /// MarketingUser id for AGENT-authored messages; null otherwise.
  authorId          String?
  body              String   @db.Text
  externalMessageId String?  @unique
  status            String   @default("SENT") // RECEIVED | SENT | DELIVERED | READ | FAILED
  error             String?
  meta              Json?
  /// Budget Autopilot conversation-spend settlement (Faz 7). `smsSegments` is the
  /// GSM-7/UCS-2 segment count for SMS; `costAmount` is the real per-message cost
  /// priced from ChannelTariff, debited to SpendLedger. Null = not yet priced.
  smsSegments       Int?
  costAmount        Decimal? @db.Decimal(14, 4)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("messages")
}

/// Inbox productivity (GHL parity) — a canned response. `shortcut` is the
/// `/slug` an agent types to insert `body`. ownerId null = shared across the
/// workspace; set = the author's private snippet. Workspace-owned.
model MessageSnippet {
  id          String   @id @default(uuid())
  workspaceId String
  ownerId     String? // null = shared; set = private to this MarketingUser
  shortcut    String // typed as /<shortcut> in the composer
  title       String
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, shortcut])
  @@index([workspaceId])
  @@map("message_snippets")
}

/// Inbox productivity (GHL parity) — an INTERNAL note on a conversation. A
/// SEPARATE model (not a Message) so it can NEVER reach a channel adapter's
/// send egress — notes are team-only and never delivered to the contact.
model ConversationNote {
  id             String   @id @default(uuid())
  workspaceId    String
  conversationId String
  authorId       String
  body           String   @db.Text
  createdAt      DateTime @default(now())

  @@index([workspaceId, conversationId, createdAt])
  @@map("conversation_notes")
}

/// Standalone trigger link (GHL parity) — a trackable short link that 302s to
/// `targetUrl` and, on each click, records a TriggerLinkClick + emits the
/// `link.clicked` workflow trigger. `slug` is GLOBALLY unique (the public route
/// /l/:slug carries no workspace context — same pattern as a webchat widgetKey).
model TriggerLink {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  slug        String   @unique // public id, globally unique
  targetUrl   String   @db.Text
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clicks TriggerLinkClick[]

  @@index([workspaceId])
  @@map("trigger_links")
}

/// One click on a TriggerLink. `leadId` is set when the link carried a `?c=`
/// contact id that resolved to a workspace lead (attribution). Cascade-deleted.
model TriggerLinkClick {
  id            String      @id @default(uuid())
  workspaceId   String
  triggerLinkId String
  triggerLink   TriggerLink @relation(fields: [triggerLinkId], references: [id], onDelete: Cascade)
  leadId        String?
  ip            String?
  userAgent     String?
  clickedAt     DateTime    @default(now())

  @@index([triggerLinkId, clickedAt])
  @@index([workspaceId, clickedAt])
  @@map("trigger_link_clicks")
}

/// An automation: a trigger (event + filters) and an ordered step list, both
/// stored as the executable-simple DSL JSON (validated by workflow-dsl.schema
/// at the API boundary). `version` bumps on every save so an in-flight run can
/// pin the definition it started on.
model Workflow {
  id          String  @id @default(uuid())
  workspaceId String
  name        String
  status      String  @default("DRAFT") // DRAFT | ACTIVE | PAUSED
  description String?
  /// DSL: { type, filters[] }.
  trigger     Json
  /// DSL: ordered step list (send_x, ai_x, branch, wait, and so on).
  steps       Json
  /// Optional goal: { filters[], onMet: 'exit'|'goto', gotoStep? }. When the
  /// subject reaches this target state the run short-circuits (GHL parity).
  goal        Json?
  version     Int     @default(1)
  /// Lightweight counters for the list UI ({ started, completed, failed }).
  stats       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("workflows")
}

/// One execution of a Workflow against one subject (usually a lead). `cursor`
/// is the frame-stack program counter (so branch/wait resume mid-flow);
/// `context` holds run variables; `depth` is the trigger-chain depth (a
/// workflow that starts another) capped at 3. A raw partial-unique index
/// (see the migration) enforces ONE active run per (workflow, lead).
model WorkflowRun {
  id              String    @id @default(uuid())
  workspaceId     String
  workflowId      String
  workflowVersion Int       @default(1)
  leadId          String?
  conversationId  String?
  status          String    @default("RUNNING") // RUNNING | WAITING | DONE | FAILED | STOPPED
  cursor          Json
  context         Json
  depth           Int       @default(0)
  lastError       String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@index([workflowId])
  @@index([leadId])
  @@map("workflow_runs")
}

/// Per-step audit trail of a run (what executed, its output, any error).
model WorkflowStepRun {
  id          String   @id @default(uuid())
  workspaceId String
  runId       String
  stepIndex   Int
  stepType    String
  status      String // DONE | FAILED | SKIPPED
  output      Json?
  error       String?
  createdAt   DateTime @default(now())

  @@index([runId])
  @@map("workflow_step_runs")
}

/// An inbound-webhook endpoint (GoHighLevel parity). An external system POSTs
/// JSON to the public hook URL identified by the globally-unique `slug`;
/// possession of the `slug` plus the `x-webhook-secret` (whose sha256 is stored
/// in `secretHash` — the raw secret is shown once at mint time and never again)
/// authenticates the call. Each accepted POST emits a `marketing.webhook.
/// received.v1` event that fires `webhook.received` workflows.
model InboundWebhook {
  id             String    @id @default(uuid())
  workspaceId    String
  name           String
  /// Globally-unique public handle in the hook URL (no workspace context in
  /// the path; the secret authenticates).
  slug           String    @unique
  /// sha256(secret) — the raw secret is never stored.
  secretHash     String
  enabled        Boolean   @default(true)
  lastReceivedAt DateTime?
  receivedCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("inbound_webhooks")
}

/// A one-to-many marketing blast on one channel. `audienceFilter` reuses the
/// workflow Filter DSL (lead.* fields). At launch the recipient set is frozen
/// into CampaignRecipient rows and sent in throttled batches. `links` is the
/// list of URLs extracted from `body` at launch so click-tracking can only ever
/// redirect to a campaign-authored URL (no open redirect).
model Campaign {
  id               String    @id @default(uuid())
  workspaceId      String
  name             String
  channel          String // EMAIL | SMS | WHATSAPP
  status           String    @default("DRAFT") // DRAFT | SCHEDULED | SENDING | SENT | PAUSED | CANCELLED
  /// A/B split test (GHL parity): when true + variants exist, each recipient is
  /// assigned a weighted-random variantKey at launch and gets that variant's
  /// subject/body. `subject`/`body` below remain the control/fallback.
  abEnabled        Boolean   @default(false)
  /// A/B mode: SPLIT = send every variant to its weighted share (default, legacy
  /// behaviour). WINNER = send the variants to abTestPercent% of the audience,
  /// then auto-send the winning variant (by abWinnerMetric) to the held-back
  /// remainder. abDecideAt schedules the decision; abWinnerKey is set once decided.
  abMode           String? // SPLIT | WINNER
  abTestPercent    Int? // 5–50: % of the audience used as the WINNER test cohort
  abWinnerMetric   String? // OPEN | CLICK
  abWinnerKey      String? // the variant key chosen as the winner
  abDecideAt       DateTime?
  subject          String?
  body             String    @db.Text
  /// Optional rendered HTML body (GHL email block builder). When set, EMAIL
  /// campaigns send this as the html part; `body` stays the plain-text fallback.
  /// Snapshotted from the EmailTemplate at launch so a later edit can't change
  /// an in-flight send.
  bodyHtml         String?   @db.Text
  /// Soft ref to the EmailTemplate this campaign was built from (display only).
  emailTemplateId  String?
  audienceFilter   Json?
  links            Json?
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  /// { recipients, sent, failed, skipped, opened, clicked, unsubscribed }.
  stats            Json?
  /// Cross-linkage (AI Social Content Studio §6.3): the companion SocialCampaign
  /// provisioned from this blast. Nullable — manual/legacy campaigns have none.
  socialCampaignId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("campaigns")
}

/// An A/B test variant of a Campaign (GoHighLevel parity). Each carries its own
/// subject + body (and optional HTML); recipients are split across variants by
/// `weight` at launch. `stats` accumulates per-variant {sent, opened, clicked}.
model CampaignVariant {
  id              String   @id @default(uuid())
  workspaceId     String
  campaignId      String
  key             String // 'A' | 'B' | … (unique per campaign)
  weight          Int      @default(1)
  subject         String?
  body            String   @db.Text
  bodyHtml        String?  @db.Text
  emailTemplateId String?
  stats           Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([campaignId, key])
  @@index([workspaceId])
  @@index([campaignId])
  @@map("campaign_variants")
}

/// A reusable HTML email template built from a block list (GoHighLevel parity).
/// `blocks` is the ordered typed list (heading/text/image/button/divider/spacer/
/// columns); `compiledHtml` is the table-based inlined-CSS render cached on save
/// (emailtemplate.render.ts). Shared by campaigns: a campaign snapshots the
/// compiled HTML into Campaign.bodyHtml at launch.
model EmailTemplate {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String
  blocks       Json
  theme        Json?
  compiledHtml String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workspaceId])
  @@map("email_templates")
}

/// A frozen recipient of a Campaign. `token` is the unguessable handle in the
/// open-pixel / click / unsubscribe links. One row per (campaign, lead).
model CampaignRecipient {
  id          String    @id @default(uuid())
  workspaceId String
  campaignId  String
  leadId      String
  token       String    @unique
  status      String    @default("PENDING") // PENDING | SENT | FAILED | SKIPPED | UNSUBSCRIBED
  /// A/B variant assigned to this recipient at launch (null = control).
  variantKey  String?
  messageId   String?
  error       String?
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?

  createdAt DateTime @default(now())

  @@unique([campaignId, leadId])
  @@index([campaignId, status])
  @@index([workspaceId])
  @@map("campaign_recipients")
}

/// A published landing page / funnel step. `blocks` is an ordered array of
/// typed content blocks (hero/features/pricing/form/cta/faq) rendered to HTML
/// server-side (no inline JS). A `form` block references a FormDef by id.
model SitePage {
  id          String  @id @default(uuid())
  workspaceId String
  slug        String
  title       String
  blocks      Json
  seo         Json?
  theme       Json?
  published   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@map("site_pages")
}

/// A lead-capture form (embedded in a SitePage `form` block). `fields` is an
/// ordered array of { name, label, type, required }. A submission creates or
/// updates a Lead and emits form.submitted (a workflow trigger).
model FormDef {
  id          String  @id @default(uuid())
  workspaceId String
  name        String
  fields      Json
  redirectUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("form_defs")
}

/// A multi-step funnel (GoHighLevel parity): an ordered sequence of SitePages
/// served as one published flow. `steps` is a JSON array of { sitePageId, name? }
/// — the funnel is the publish unit, and the public renderer reuses the page's
/// block list per step + appends a "Continue" link to the next step.
model Funnel {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  slug        String
  /// Ordered [{ sitePageId, name? }] — each step renders that page's blocks.
  steps       Json
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@map("funnels")
}

/// A bookable calendar with weekly availability. `availability` is a per-weekday
/// list of {start,end} HH:mm windows; bookable slots = windows sliced into
/// slotMinutes, minus existing bookings, plus bufferMinutes between.
model BookingCalendar {
  id            String  @id @default(uuid())
  workspaceId   String
  name          String
  slug          String
  ownerUserId   String?
  // GHL calendar types. SINGLE = one owner (current behavior). ROUND_ROBIN =
  // distribute each booking across `members` (one assignee per booking).
  // COLLECTIVE = the whole team for one booking (capacity 1). CLASS = a group
  // event with multiple attendees up to `capacity`. Effective per-slot capacity
  // is derived: SINGLE/COLLECTIVE→1, CLASS→capacity, ROUND_ROBIN→member count.
  type          String  @default("SINGLE") // SINGLE | ROUND_ROBIN | COLLECTIVE | CLASS
  capacity      Int     @default(1) // attendees per slot for CLASS
  availability  Json
  slotMinutes   Int     @default(30)
  bufferMinutes Int     @default(0)
  timezone      String  @default("Europe/Istanbul")
  active        Boolean @default(true)

  // Which conferencing provider to attach to this calendar's bookings.
  conferencing     String @default("NONE") // NONE | GOOGLE_MEET | TEAMS
  // Advanced-Meet config (recording/transcript/co-host), read only by Phase 4.
  conferenceConfig Json?

  // Booking policy (Phase 2). minNotice = earliest lead time before a slot;
  // maxAdvance = furthest bookable day (replaces the old hard-coded 21). Buffers
  // are dead time offered BEFORE/AFTER each slot. requiresApproval holds new
  // bookings as PENDING until a manager confirms. reminderConfig is an array of
  // {offsetMinutes, channels:['EMAIL'|'SMS'], audience:'CUSTOMER'|'HOST'|'BOTH'}.
  minNoticeMinutes    Int     @default(0)
  maxAdvanceDays      Int     @default(60)
  bufferBeforeMinutes Int     @default(0)
  bufferAfterMinutes  Int     @default(0)
  requiresApproval    Boolean @default(false)
  reminderConfig      Json?

  members BookingCalendarMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@map("booking_calendars")
}

/// A team member assigned to a ROUND_ROBIN / COLLECTIVE calendar. `priority`
/// orders round-robin assignment (lower first as a tie-break). marketingUserId
/// is a soft ref (no FK, multi-tenant pattern). Cascade-deleted with its calendar.
model BookingCalendarMember {
  id              String          @id @default(uuid())
  workspaceId     String
  calendarId      String
  calendar        BookingCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  marketingUserId String
  priority        Int             @default(0)
  createdAt       DateTime        @default(now())

  @@unique([calendarId, marketingUserId])
  @@index([workspaceId, calendarId])
  @@map("booking_calendar_members")
}

/// Time-off / blackout window that hard-blocks bookings (Phase 2). calendarId
/// null = all calendars in the workspace; marketingUserId null = whole calendar,
/// set = one staff member's personal time off (only blocks that assignee).
model BookingBlackout {
  id              String   @id @default(uuid())
  workspaceId     String
  calendarId      String?
  marketingUserId String?
  startAt         DateTime
  endAt           DateTime
  reason          String?
  createdAt       DateTime @default(now())

  @@index([workspaceId, calendarId])
  @@index([workspaceId, marketingUserId])
  @@map("booking_blackouts")
}

/// Per-member working hours for a ROUND_ROBIN/COLLECTIVE calendar (Phase 2).
/// When present, that member is only offered inside calendar ∩ member windows.
model MemberAvailability {
  id              String   @id @default(uuid())
  workspaceId     String
  calendarId      String
  marketingUserId String
  availability    Json // same weekday-index -> [{start,end}] shape as BookingCalendar
  timezone        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([calendarId, marketingUserId])
  @@index([workspaceId])
  @@map("member_availability")
}

/// A booked slot. Creating one mints/links a Lead, emits booking.created (a
/// workflow trigger), emails an ICS invite, and schedules a booking.reminder.
model Booking {
  id             String   @id @default(uuid())
  workspaceId    String
  calendarId     String
  leadId         String?
  startAt        DateTime
  endAt          DateTime
  name           String
  email          String?
  phone          String?
  notes          String?
  status         String   @default("CONFIRMED") // CONFIRMED | CANCELLED | EXTERNAL_BUSY (pulled from Google)
  // The team member this booking is assigned to (round-robin pick; the owner
  // for SINGLE/COLLECTIVE). Soft ref to a marketing user; null for class attendees.
  assigneeUserId String?
  token          String   @unique

  // Google Calendar 2-way sync: the mirrored Google event id (nullable). For
  // our bookings pushed to Google it is the created event's id; for "busy"
  // blocks pulled FROM Google (status EXTERNAL_BUSY) it is the source event id.
  googleEventId String?

  // Outlook/O365 (Microsoft Graph) 2-way sync, same shape as googleEventId. A
  // transient `pending:<uuid>` value claims the create so two concurrent push
  // paths can't mint duplicate Graph events (Graph has no client-supplied ids).
  outlookEventId String?

  // Conferencing (Phase 1): the video-meeting join link mirrored onto the
  // booking. provider = GOOGLE_MEET | TEAMS; conferenceId = hangout / Teams
  // onlineMeeting id (teardown + pending follow-up); status = created | pending
  // | failed | none (null = no conferencing on this calendar).
  meetingUrl         String?
  conferenceProvider String?
  conferenceId       String?
  conferenceStatus   String?

  // Phase 2: the attendee's IANA timezone (captured at reserve) for
  // customer-facing times; rescheduledFromId links a reschedule chain (the new
  // booking points at the RESCHEDULED old one).
  attendeeTimezone  String?
  rescheduledFromId String?

  createdAt DateTime @default(now())

  @@index([calendarId, startAt])
  @@index([workspaceId])
  @@index([workspaceId, googleEventId])
  @@index([workspaceId, outlookEventId])
  @@map("bookings")
}

/// A place reviews are collected (v1: a Google Business "leave a review" URL).
model ReviewSource {
  id           String    @id @default(uuid())
  workspaceId  String
  type         String    @default("GOOGLE") // GOOGLE | FACEBOOK
  name         String
  placeUrl     String
  // Review-sync (Epic 13, inert until a Google Business / FB page token): the
  // place/location/page id, a SEALED OAuth token, and the sweep bookkeeping.
  placeId      String?
  accessToken  String? // SEALED (secret-box) — masked out of responses
  externalRef  String? // provider account/location ref (e.g. accounts/{a}/locations/{l})
  syncStatus   String    @default("ACTIVE") // ACTIVE | PAUSED | ERROR
  lastSyncedAt DateTime?
  lastError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@map("review_sources")
}

/// A review-request / review. The `send_review_request` workflow action mints
/// one (status REQUESTED + token) and sends the lead the rating-gate link
/// (/r/:token): ≥4 stars routes to the public source URL (PUBLIC_ROUTED), <4
/// captures private feedback (PRIVATE_FEEDBACK). The team can AI-draft a reply.
model Review {
  id               String    @id @default(uuid())
  workspaceId      String
  sourceId         String?
  leadId           String?
  rating           Int?
  text             String?   @db.Text
  authorName       String?
  status           String    @default("REQUESTED") // REQUESTED | PUBLIC_ROUTED | PRIVATE_FEEDBACK | REPLIED | SYNCED
  replyDraft       String?   @db.Text
  replyText        String?   @db.Text
  token            String    @unique
  // Review-sync (Epic 13): a synced public review carries the provider's review
  // id (idempotency key per source) + origin + authored time. Gate reviews leave
  // these null.
  source           String    @default("GATE") // GATE | GOOGLE | FACEBOOK
  externalReviewId String?
  authoredAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceId, externalReviewId])
  @@index([workspaceId, status])
  @@map("reviews")
}

/// An inbound AI-answered phone call (Twilio). The agent persona comes from the
/// VOICE Channel's agentProfileId; turns are transcribed into VoiceTranscript.
model VoiceCall {
  id              String   @id @default(uuid())
  workspaceId     String
  channelId       String
  leadId          String?
  externalCallId  String   @unique
  fromNumber      String
  toNumber        String
  status          String   @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | FAILED
  turns           Int      @default(0)
  lastGatherToken String?
  /// Budget Autopilot: billable duration + real per-minute cost (ChannelTariff
  /// VOICE_MINUTE), debited to SpendLedger. Null = not yet settled.
  billableSeconds Int?
  costAmount      Decimal? @db.Decimal(14, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, createdAt])
  @@map("voice_calls")
}

/// One turn of a voice call transcript.
model VoiceTranscript {
  id          String   @id @default(uuid())
  workspaceId String
  callId      String
  role        String // CUSTOMER | AI | SYSTEM
  text        String   @db.Text
  createdAt   DateTime @default(now())

  @@index([callId])
  @@map("voice_transcripts")
}

/// A configurable IVR / phone-tree menu (GoHighLevel parity). Sits IN FRONT OF
/// the existing Voice-AI flow: when a workspace has an enabled `isRoot` menu,
/// inbound calls are answered with this menu's <Gather numDigits=1> instead of
/// going straight to the AI receptionist. Workspace-owned. `greeting` is either
/// plain text (spoken via <Say>) or an absolute audio URL (played via <Play>).
model IvrMenu {
  id          String  @id @default(uuid())
  workspaceId String
  name        String
  greeting    String  @db.Text
  enabled     Boolean @default(true)
  isRoot      Boolean @default(false) // the entry menu for inbound calls

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options IvrOption[]

  @@index([workspaceId])
  // At most ONE enabled root menu per workspace is enforced in the service
  // layer (a partial unique index can't express "enabled AND isRoot" portably
  // here); this index makes the root lookup on the inbound webhook cheap.
  @@index([workspaceId, isRoot, enabled])
  @@map("ivr_menus")
}

/// One keypad option on an IvrMenu. `digit` is unique within a menu. `action`
/// decides what the digit does: SUBMENU (nested <Gather> via targetMenuId),
/// DIAL (<Dial> the E.164 dialNumber), VOICEMAIL (<Record>), HANGUP (<Hangup>),
/// or AI_RECEPTIONIST (hand off to the existing Voice-AI flow).
model IvrOption {
  id           String  @id @default(uuid())
  workspaceId  String
  menuId       String
  digit        String // '0'-'9' | '*' | '#'
  label        String
  action       String // SUBMENU | DIAL | VOICEMAIL | HANGUP | AI_RECEPTIONIST
  targetMenuId String? // for SUBMENU
  dialNumber   String? // for DIAL, E.164

  createdAt DateTime @default(now())

  menu IvrMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([menuId, digit])
  @@index([workspaceId])
  @@map("ivr_options")
}

/// An invoice the workspace sends to its OWN end customer. `items` is an array
/// of { description, qty, unitPrice }; `total` is denormalized. Paid via the
/// workspace's own PSP (WorkspacePspConfig) on the public /i/:token page.
/// Customer store-credit wallet (GHL parity). One per (workspace, lead). The
/// ledger is the source of truth; `balance` is a cached running total kept in
/// sync inside the same transaction as every entry (so a read is O(1) and a
/// concurrent credit/debit can't lose an update — the increment is atomic).
model CustomerWallet {
  id          String   @id @default(uuid())
  workspaceId String
  leadId      String
  balance     Int      @default(0) // minor units (cached ledger sum)
  currency    String   @default("TRY")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ledger WalletLedgerEntry[]

  @@unique([workspaceId, leadId])
  @@index([workspaceId])
  @@map("customer_wallets")
}

/// One append-only movement on a CustomerWallet. `delta` is signed minor units
/// (credit > 0, debit < 0). Cascade-deleted with the wallet.
model WalletLedgerEntry {
  id          String         @id @default(uuid())
  workspaceId String
  walletId    String
  wallet      CustomerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  delta       Int // signed minor units
  reason      String // CREDIT | DEBIT | REFUND | MANUAL_ADJUST
  invoiceId   String?
  note        String?
  createdAt   DateTime       @default(now())

  @@index([walletId, createdAt])
  @@index([workspaceId])
  @@map("wallet_ledger_entries")
}

/// A discount coupon (GHL parity). PERCENT (value = whole percent) or FIXED
/// (value = minor units off). Server-validated on redemption: active + within
/// the optional window + under maxRedemptions + over minSubtotal. `code` is
/// unique per workspace. Workspace-owned.
model Coupon {
  id             String    @id @default(uuid())
  workspaceId    String
  code           String
  kind           String // PERCENT | FIXED
  value          Int // PERCENT: 1–100; FIXED: minor units
  currency       String? // FIXED only — must match the document currency
  minSubtotal    Int? // minor units; coupon invalid below this
  maxRedemptions Int? // null = unlimited
  timesRedeemed  Int       @default(0)
  startsAt       DateTime?
  expiresAt      DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  redemptions CouponRedemption[]

  @@unique([workspaceId, code])
  @@index([workspaceId, active])
  @@map("coupons")
}

/// One redemption of a Coupon (append-only). `amountOff` is the server-resolved
/// discount in minor units. Tied to the invoice/order-form it discounted.
model CouponRedemption {
  id          String   @id @default(uuid())
  workspaceId String
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  invoiceId   String?
  orderFormId String?
  leadId      String?
  amountOff   Int
  redeemedAt  DateTime @default(now())

  @@index([couponId, redeemedAt])
  @@index([workspaceId])
  @@map("coupon_redemptions")
}

/// A reusable tax rate (GHL parity) — e.g. "KDV %20". `rate` is a percentage
/// (20.00 = 20%); applied EXCLUSIVELY (added on top of the line subtotal).
/// Workspace-owned. Per-line a document snapshots the resolved rate so editing a
/// TaxRate later never rewrites historical invoice/estimate totals.
model TaxRate {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  rate        Decimal  @db.Decimal(5, 2) // percent, e.g. 20.00
  isDefault   Boolean  @default(false)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId, archived])
  @@map("tax_rates")
}

model Invoice {
  id          String    @id @default(uuid())
  workspaceId String
  leadId      String?
  number      String
  items       Json
  currency    String    @default("TRY")
  // Money breakdown in minor units. `total` = subtotal + taxTotal. subtotal/
  // taxTotal default 0 (legacy invoices had only `total`; treat subtotal=total
  // when both breakdown columns are 0).
  subtotal    Int       @default(0)
  taxTotal    Int       @default(0)
  // Coupon discount applied after tax (minor units). total = subtotal + taxTotal
  // − discount (clamped ≥ 0). Default 0 = no discount.
  discount    Int       @default(0)
  total       Int       @default(0) // minor units (kuruş/cents)
  notes       String?
  dueDate     DateTime?
  status      String    @default("DRAFT") // DRAFT | SENT | PAID | VOID
  publicToken String    @unique
  paidAt      DateTime?
  paidVia     String?

  // Set when this invoice was minted by the CustomerSubscription sweep (null for
  // hand-made invoices). The partial-unique index on (subscriptionId,
  // subscriptionPeriodKey) — added in raw SQL, Prisma can't model partial-unique
  // — makes "one invoice per (subscription, period)" a DB invariant, so a double
  // sweep / retry can never double-bill.
  subscriptionId        String?
  subscriptionPeriodKey String? // e.g. "2026-06" — the period this invoice settles

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@index([subscriptionId])
  @@map("invoices")
}

/// Epic — Recurring customer subscriptions (GoHighLevel parity). An hourly sweep
/// mints a DRAFT Invoice each billing period from each due subscription; it does
/// NOT auto-charge — the workspace collects via the existing invoice pay flow.
/// DISTINCT from `WorkspaceSubscription` (the platform's SaaS billing of the
/// workspace). `items` is the InvoiceItem[] snapshot ({description,qty,unitPrice}
/// minor units); soft workspace scoping (no FK).
model CustomerSubscription {
  id          String  @id @default(uuid())
  workspaceId String
  leadId      String? // standalone allowed (nullable)

  name     String // human label, e.g. "Gold membership"
  items    Json // InvoiceItem[] snapshot
  currency String  @default("TRY")
  amount   Int     @default(0) // minor-unit sum of items (display/sanity; recomputed server-side)
  notes    String?
  dueDays  Int     @default(14) // generated invoice dueDate = issue date + dueDays

  interval      String @default("MONTH") // MONTH | YEAR | WEEK
  intervalCount Int    @default(1) // every N intervals

  status              String    @default("ACTIVE") // ACTIVE | PAUSED | CANCELLED
  anchorAt            DateTime  @default(now())
  nextBillingAt       DateTime // the sweep mints when this is <= now
  lastBilledAt        DateTime?
  lastBilledPeriodKey String?
  invoicesGenerated   Int       @default(0)
  // Consecutive failed sweep attempts (transient errors). Reset to 0 on a
  // successful/skipped bill. The sweep stops retrying a row once this hits the
  // cap (poison-pill guard) so one bad subscription can't occupy a batch slot
  // forever; the row is then surfaced for manual attention.
  failedAttempts      Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextBillingAt])
  @@index([workspaceId, status])
  @@map("customer_subscriptions")
}

/// The workspace's OWN payment config for billing ITS customers (distinct from
/// the platform's billing PSP). Secret keys/IBAN are AES-256-GCM sealed.
model WorkspacePspConfig {
  id           String  @id @default(uuid())
  workspaceId  String  @unique
  provider     String  @default("MANUAL") // STRIPE | PAYTR | MANUAL
  configSealed String? @db.Text
  configPublic Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspace_psp_configs")
}

/// White-label-lite: the workspace's brand applied to its public-facing
/// surfaces (funnel pages, web-chat widget, …). `logoUrl` points at an uploaded
/// asset under UPLOADS_DIR (served at /api/public/uploads) or any https URL.
model WorkspaceBranding {
  id          String  @id @default(uuid())
  workspaceId String  @unique
  brandName   String?
  accentColor String? // #RRGGBB
  logoUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("workspace_branding")
}

model OutboxEvent {
  // UUIDv7 generated at the application layer so events sort by creation time
  // without needing a sequence; safe across replicas.
  id             String    @id
  // Versioned dotted name, e.g. "subscription.activated.v1", "order.created.v1".
  type           String
  tenantId       String?
  // The full event body. Consumers parse this with Zod against the event
  // contract in packages/event-contracts.
  payload        Json
  // Idempotency key emitted by the producer (often the same as id, but kept
  // separate so the same logical event can be re-emitted with a fresh id if
  // ever needed). Consumers dedupe on this.
  idempotencyKey String
  // Drain state machine: queued -> dispatching -> dispatched | failed.
  status         String    @default("queued")
  attempts       Int       @default(0)
  lastError      String?
  // Time the worker first dispatched the event to the bus. Used to compute
  // delivery lag p95 in observability.
  dispatchedAt   DateTime?
  // Earliest moment the worker should attempt redelivery after a failure.
  // Exponential backoff lives in OutboxWorkerService.
  nextAttemptAt  DateTime?
  // Stamped when the worker claims a row (queued -> dispatching). A row whose
  // claimedAt is older than the reclaim window was orphaned by a crash between
  // the claim commit and the terminal flip; the reclaim sweep re-queues it.
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())

  // Worker scans `status='queued' AND nextAttemptAt <= now()` in id order.
  @@index([status, nextAttemptAt])
  @@index([type, createdAt])
  @@index([tenantId, createdAt])
  // Reclaim sweep scans `status='dispatching' AND claimedAt < cutoff`.
  @@index([status, claimedAt])
  @@map("outbox_events")
}

/// Append-only audit trail (Auditability / Security) — backlog #3.
///
/// Formalizes what used to live implicitly across the schema (commission
/// approval stamps, offer snapshots, operator action timestamps) into one
/// queryable, tamper-evident log of material state changes: who did what to
/// which resource, when, from where, and whether it succeeded.
///
/// APPEND-ONLY by contract: AuditLogService only ever inserts — there is no
/// update/delete path in the service layer. Rows are written out-of-band by the
/// AuditInterceptor and MUST NOT participate in the request's transaction, so a
/// failed audit write can never roll back (or be rolled back by) the business
/// action it records.
model AuditLog {
  id         String   @id @default(uuid())
  occurredAt DateTime @default(now())

  // WHO — the principal that performed the action, by realm. actorId/email are
  // null for SYSTEM/anonymous actions (e.g. an unauthenticated webhook).
  actorType  String // PLATFORM_OPERATOR | MARKETING_USER | SERVICE | SYSTEM
  actorId    String?
  actorEmail String?

  // WHAT — a stable dotted action name plus the targeted resource.
  action       String // e.g. "workspace.status.update", "commission.approve"
  resourceType String // e.g. "workspace", "order", "commission", "lead"
  resourceId   String?

  // WHERE — tenant scope (when the action is workspace-scoped) + tracing.
  workspaceId String?
  requestId   String?
  ip          String?

  // OUTCOME + detail. metadata holds a small whitelisted slice of the request
  // (e.g. the new status), never secrets or full bodies.
  outcome  String @default("SUCCESS") // SUCCESS | FAILURE
  metadata Json?

  @@index([workspaceId, occurredAt])
  @@index([resourceType, resourceId])
  @@index([actorId, occurredAt])
  @@index([action, occurredAt])
  @@map("audit_log")
}

/// Platform-level configuration for the 4 cloud routines (review-draft,
/// content-pack, insight-digest, lead-scoring). Each row holds the trigger
/// URL + sealed token so the operator pastes claude.ai "Call via API"
/// credentials once and the backend owns when each routine runs.
model RoutineConfig {
  id                 String    @id @default(uuid())
  /// review-draft | content-pack | insight-digest | lead-scoring
  key                String    @unique
  enabled            Boolean   @default(false)
  /// Cron expression for the backend scheduler (null = no schedule; manual/event only).
  cron               String?
  /// React to domain events (review-draft: new private feedback; lead-scoring: lead ingest).
  onEvent            Boolean   @default(false)
  /// claude.ai "Call via API" trigger endpoint.
  triggerUrl         String?
  /// AES-256-GCM sealed token (v1:<iv>:<tag>:<ct>). Written once per PATCH; never read back to callers.
  triggerTokenSealed String?   @db.Text
  /// Minimum seconds between event-driven triggers (debounce bursts).
  eventCooldownSec   Int       @default(300)
  lastTriggeredAt    DateTime?
  lastTriggerStatus  String? // ok | error
  lastTriggerError   String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("routine_configs")
}

/// Epic C1 — a workspace-authored course. Content lives in CourseModule →
/// Lesson. Members are Leads (soft ref via Enrollment). Publishing requires
/// at least one lesson (enforced in the service).
model Course {
  id                  String   @id @default(uuid())
  workspaceId         String
  title               String
  slug                String
  description         String?  @db.Text
  status              String   @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  priceCents          Int? // null = free
  currency            String?
  coverImageUrl       String?
  position            Int      @default(0)
  // Course-level default lesson gating (Epic 10a drip). A lesson keeps its own
  // gating unless that is FREE, in which case this course default applies — so an
  // operator can gate/drip a whole course without editing every lesson.
  dripMode            String? // null/FREE | SEQUENTIAL | DRIP
  // Completion certificates (Epic 10b). When enabled, a Certificate is issued
  // the moment an enrollment reaches 100%. The template holds {title?, signature?,
  // logoUrl?} for the rendered certificate.
  certificateEnabled  Boolean  @default(false)
  certificateTemplate Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  modules      CourseModule[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@map("courses")
}

/// Epic C2 — a Lead's enrollment in a Course. `leadId` is a soft ref to the
/// contact (the member). progressPct is recomputed from LessonProgress on each
/// completion; status flips COMPLETED at 100%.
model Enrollment {
  id          String    @id @default(uuid())
  workspaceId String
  courseId    String
  leadId      String
  status      String    @default("ACTIVE") // ACTIVE | COMPLETED | CANCELLED
  progressPct Int       @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([courseId, leadId])
  @@index([workspaceId, courseId])
  @@index([workspaceId, leadId])
  @@map("enrollments")
}

model LessonProgress {
  id           String    @id @default(uuid())
  enrollmentId String
  lessonId     String
  completed    Boolean   @default(false)
  completedAt  DateTime?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId, completed])
  @@map("lesson_progress")
}

/// Epic 10b — a completion certificate. Issued once per (course, lead)
/// completion — keyed on the stable business identity, NOT the enrollment row,
/// so an unenroll + re-enroll (which mints a new enrollment id) can't produce a
/// duplicate credential. `enrollmentId` records the enrollment that triggered
/// issuance (audit). `serial` is the unguessable public handle (verify page);
/// `leadId` is a soft ref. Rendered to printable HTML on demand (no file storage).
model Certificate {
  id           String   @id @default(uuid())
  workspaceId  String
  enrollmentId String
  courseId     String
  leadId       String
  serial       String   @unique
  issuedAt     DateTime @default(now())
  pdfUrl       String? // reserved: a pre-rendered artifact URL if ever materialized

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, courseId, leadId])
  @@map("certificates")
}

/// Epic 10c — append-only points ledger for membership gamification. Points
/// accrue to a Lead (member) from learning/community activity. The
/// (workspaceId, leadId, source, refId) unique makes each award idempotent — the
/// same lesson/course/post can't double-award. `points` is a signed delta.
model PointsLedger {
  id          String   @id @default(uuid())
  workspaceId String
  leadId      String
  source      String // LESSON_COMPLETE | COURSE_COMPLETE | POST_CREATED | COMMENT
  points      Int
  refId       String? // the lesson/course/post/comment id this award is for
  createdAt   DateTime @default(now())

  @@unique([workspaceId, leadId, source, refId])
  @@index([workspaceId, leadId])
  @@map("points_ledger")
}

/// Epic 10c — a workspace-defined badge. `ruleType` + `threshold` decide when a
/// member earns it (POINTS = total points; LESSONS = distinct lessons completed;
/// COURSES = courses completed).
model Badge {
  id          String   @id @default(uuid())
  workspaceId String
  key         String
  name        String
  iconUrl     String?
  ruleType    String // POINTS | LESSONS | COURSES
  threshold   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([workspaceId, key])
  @@index([workspaceId])
  @@map("badges")
}

/// Epic 10c — a badge a member (Lead) has earned (idempotent per lead+badge).
model EarnedBadge {
  id          String   @id @default(uuid())
  workspaceId String
  leadId      String
  badgeId     String
  earnedAt    DateTime @default(now())

  @@unique([workspaceId, leadId, badgeId])
  @@index([workspaceId, leadId])
  @@map("earned_badges")
}

/// Epic C3 — a community space. Members are Leads; posts/comments may be
/// authored by a staff MarketingUser (authorUserId) or a member Lead
/// (authorLeadId), both soft refs.
/// DEPRECATED (2026-07 system trim): the communities feature was removed — no UI or
/// API serves this model anymore. The table + any tenant data are RETAINED
/// on purpose (no destructive migration); drop in a later cleanup once the
/// owner confirms zero production usage.
model Community {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  slug        String
  description String?  @db.Text
