/// Epic G — env-gated enterprise SSO via OIDC (authorization-code + PKCE).
/// One row per workspace IdP. `clientSecret` is stored SEALED with the
/// AES-256-GCM secret-box (env MARKETING_SECRET_KEY) and is NEVER returned by
/// the API. `allowedDomains` (when non-empty) restricts which verified email
/// domains may JIT-provision/match a user. Inert when no enabled row exists or
/// the secret-box is unconfigured — the feature is simply unavailable.
model SsoConnection {
  id             String   @id @default(uuid())
  workspaceId    String
  provider       String   @default("OIDC") // OIDC (only mode today)
  issuer         String // OIDC issuer base URL; token/JWKS discovered from it
  clientId       String
  clientSecret   String // SEALED (secret-box v1:...); masked out of API responses
  enabled        Boolean  @default(false)
  allowedDomains String[] @default([]) // empty = any verified email domain
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, enabled])
  @@map("sso_connections")
}

/// Env-gated Google Calendar 2-way sync. One row per (workspace, connecting
/// MarketingUser, googleCalendar). OAuth tokens are stored SEALED (secret-box
/// v1:...) and NEVER returned by the API. `syncToken` drives incremental pulls;
/// `channelId`/`resourceId` back the optional Google "watch" push-webhook.
model GoogleCalendarConnection {
  id                String    @id @default(uuid())
  workspaceId       String
  marketingUserId   String
  googleCalendarId  String    @default("primary")
  accessToken       String // SEALED (secret-box v1:...) — masked out of API responses
  refreshToken      String // SEALED (secret-box v1:...) — masked out of API responses
  tokenExpiresAt    DateTime
  syncToken         String? // Google incremental events.list sync token (nullable until first pull)
  channelId         String? // Google watch channel id (push webhook); unique when set
  resourceId        String? // Google watch resource id (push webhook)
  channelToken      String? // per-channel verification nonce (validated on the incoming webhook)
  channelExpiration DateTime? // when the Google watch channel expires (drives the renewal cron)
  // Space-separated OAuth scopes Google granted (Phase 4). Presence of
  // meetings.space.created gates advanced Meet (recording/transcript/co-host).
  scopes            String?
  enabled           Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([channelId])
  @@index([workspaceId])
  @@index([workspaceId, marketingUserId])
  @@map("google_calendar_connections")
}

/// Epic 12 (needs-external, inert until an Azure AD app + MS_OAUTH creds) —
/// Microsoft Outlook/O365 calendar connection. Mirrors GoogleCalendarConnection:
/// sealed access/refresh tokens, a Graph delta cursor, and (for the deferred
/// real-time sync) a change-notification subscription.
model OutlookCalendarConnection {
  id                     String    @id @default(uuid())
  workspaceId            String
  marketingUserId        String
  outlookCalendarId      String    @default("primary")
  accessToken            String // SEALED — masked out of API responses
  refreshToken           String // SEALED — masked out of API responses
  tokenExpiresAt         DateTime
  deltaToken             String? // Graph /me/events delta cursor (nullable until first pull)
  subscriptionId         String? // Graph change-notification subscription id; unique when set
  clientState            String? // per-subscription verification nonce
  subscriptionExpiration DateTime? // when the Graph subscription expires (drives renewal)
  enabled                Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([subscriptionId])
  @@index([workspaceId])
  @@index([workspaceId, marketingUserId])
  @@map("outlook_calendar_connections")
}

/// Epic F — a workspace-defined custom role with a granular permission set
