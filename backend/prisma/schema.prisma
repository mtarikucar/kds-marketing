model BrandKit {
  id              String   @id @default(uuid())
  workspaceId     String   @unique
  logoUrl         String?
  logoR2Key       String?
  /// Array of hex color strings.
  palette         Json?
  tone            String?  @db.Text
  /// [{ url, r2Key, mime }] — 3–5 reference images (R2).
  referenceImages Json     @default("[]")
  defaultHashtags String[]
  defaultCta      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("brand_kits")
}

/// A single AI-generated media asset (image or video) and its generation
/// lifecycle. status: QUEUED|GENERATING|READY|FAILED|BLOCKED. fal result URLs
/// are re-hosted to R2 on READY; `r2Key` is the canonical store.
model GeneratedAsset {
  id                  String          @id @default(uuid())
  workspaceId         String
  type                String // IMAGE | VIDEO
  status              String          @default("QUEUED") // QUEUED|GENERATING|READY|FAILED|BLOCKED
  provider            String // e.g. "fal"
  model               String // provider model id
  providerRequestId   String? // idempotency key for webhook/poll convergence
  prompt              String          @db.Text
  negativePrompt      String?
  /// aspectRatio, durationSec, seed, referenceImageUrls, count, etc.
  params              Json            @default("{}")
  url                 String?
  r2Key               String?
  mime                String?
  width               Int?
  height              Int?
  durationSec         Float?
  thumbnailUrl        String?
  thumbnailR2Key      String?
  costCredits         Int? // reconciled actual
  costCreditsReserved Int? // estimate reserved at submit (for refund/reconcile)
  costUsd             Decimal?        @db.Decimal(10, 4)
  error               String?
  socialCampaignId    String?
  socialCampaign      SocialCampaign? @relation(fields: [socialCampaignId], references: [id], onDelete: SetNull)
  createdById         String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([workspaceId, status])
  @@index([providerRequestId])
  @@map("generated_assets")
}

enum SocialCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum SocialCampaignAutomationMode {
  APPROVAL
  SEMI_AUTO
  FULL_AUTO
}

enum SocialCampaignPlanningMode {
  AI_PROPOSE
  AI_FULL
  USER_TOPICS
}

enum SocialCampaignItemStatus {
  PLANNED
  GENERATING
  NEEDS_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
  SKIPPED
}

/// AI Social Content Studio — a goal/theme/cadence-driven content calendar that
/// auto-progresses generated posts. One per workspace per campaign.
model SocialCampaign {
  id                 String                       @id @default(uuid())
  workspaceId        String
  name               String
  goal               String?
  theme              String?
  /// { audience?, keyMessages?, languages?, productRefs?, topics?[] }
  brief              Json
  status             SocialCampaignStatus         @default(DRAFT)
  automationMode     SocialCampaignAutomationMode
  planningMode       SocialCampaignPlanningMode
  /// { perWeek?, daysOfWeek:number[], timeOfDay:'HH:MM', timezone? }
  cadence            Json
  startDate          DateTime
  endDate            DateTime?
  targetAccountIds   String[]
  mediaKinds         String[]
  defaultImageModel  String?
  defaultVideoModel  String?
  dailyPublishCap    Int                          @default(2)
  linkedCampaignId   String?
  linkedAdCampaignId String?
  /// Set when the Growth Autopilot ENGINE provisioned this campaign (= the
  /// GrowthBudget id it belongs to). Makes one-click provisioning idempotent:
  /// re-running quick-start skips accounts already backed by an active
  /// engine-owned campaign for the budget's period. Null = user-authored.
  engineBudgetId     String?
  /// { planned, generated, approved, published }
  stats              Json?
  createdById        String
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  items  SocialCampaignItem[]
  assets GeneratedAsset[]

  @@index([workspaceId, status])
  @@index([workspaceId, engineBudgetId])
  @@map("social_campaigns")
}

/// One planned slot in a SocialCampaign's calendar.
model SocialCampaignItem {
  id                String                   @id @default(uuid())
  socialCampaignId  String
  campaign          SocialCampaign           @relation(fields: [socialCampaignId], references: [id], onDelete: Cascade)
  workspaceId       String
  sequenceIndex     Int
  scheduledFor      DateTime
  status            SocialCampaignItemStatus @default(PLANNED)
  topic             String?
  socialPostId      String?
  generatedAssetIds String[]
  error             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([socialCampaignId, status])
  @@index([workspaceId, status])
  @@map("social_campaign_items")
}

/// Epic D1 — agency config SNAPSHOT (GoHighLevel "snapshot" parity).
///
/// A reusable capture of one workspace's CONFIG (custom-field defs, tags,
/// segments, workflows, agent profiles, funnels/pages, forms, booking calendars,
/// knowledge docs, review sources) — NEVER customer data (leads, conversations,
/// offers, invoices, users). `workspaceId` is the AGENCY that captured it, so a
/// snapshot is a normal workspace-OWNED row (same scoping invariant as every
/// other owned delegate). `payload` stores each captured record in its PORTABLE
/// shape (stripped of id / workspaceId / timestamps), keyed by config type, so
/// `apply` can stamp the target workspaceId and idempotently re-create the config
/// in a child LOCATION (authorized via assertAgencyOwns).
model Snapshot {
  id          String   @id @default(uuid())
  workspaceId String // the AGENCY that owns this snapshot
  name        String
  description String?
  payload     Json // captured config, keyed by type (portable shape)
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("snapshots")
}

/// Epic D1 — agency REBILLING / SaaS-mode (GoHighLevel "agency charges sub-account"
/// parity). One plan per child LOCATION: the flat monthly SaaS fee the agency charges
/// it, plus a markup applied to that location's REAL metered usage (read from
/// UsageCounter — the same `ai.credits` / `messages.sent` meters the product already
/// writes). `workspaceId` is the AGENCY that owns the plan (normal owned-delegate
/// scoping); `locationWorkspaceId` is its child LOCATION, authorized via
/// assertAgencyOwns at the service layer (no DB FK, matching the soft-reference style).
/// Money is Decimal(10,2) TRY — identical semantics to packages/invoices; this module
/// is additive and never touches the existing customer billing tables.
model RebillingPlan {
  id                  String   @id @default(uuid())
  workspaceId         String // the AGENCY that owns this plan
  locationWorkspaceId String // the child LOCATION it bills
  basePrice           Decimal  @default(0) @db.Decimal(10, 2) // flat monthly SaaS fee (TRY)
  usageUnitPrice      Decimal  @default(0) @db.Decimal(10, 2) // agency cost basis per metered usage unit (TRY)
  markupPercent       Decimal  @default(0) @db.Decimal(10, 2) // % markup the agency adds on metered usage
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([workspaceId, locationWorkspaceId])
  @@index([workspaceId])
  @@map("rebilling_plans")
}

/// Epic D1 — a monthly REBILL settlement line per location. computeCharge meters the
/// location's REAL usage over [periodStart, periodEnd) and records a DRAFT charge:
/// baseAmount = plan.basePrice, usageAmount = meteredUnits × usageUnitPrice ×
/// (1 + markupPercent/100), totalAmount = baseAmount + usageAmount. The actual
/// outbound charge (chargeViaStripeConnect) is ENV-GATED: when Stripe Connect is not
/// configured the charge stays DRAFT (internal settlement only, no live charge);
/// when configured it flips to INVOICED/PAID and stores `stripeChargeId`. Idempotent.
model RebillCharge {
  id                  String   @id @default(uuid())
  workspaceId         String // the AGENCY that owns this charge
  locationWorkspaceId String // the child LOCATION being settled
  periodStart         DateTime
  periodEnd           DateTime
  baseAmount          Decimal  @default(0) @db.Decimal(10, 2)
  usageAmount         Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount         Decimal  @default(0) @db.Decimal(10, 2)
  usageUnits          Int      @default(0) // raw metered units the usage line settled (audit trail)
  status              String   @default("DRAFT") // DRAFT | INVOICED | PAID | FAILED
  stripeChargeId      String?
  createdAt           DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, locationWorkspaceId])
  @@map("rebill_charges")
}

/// Epic — Sales Opportunities (GoHighLevel parity). A workspace defines one or
/// more named Pipelines; each Pipeline is an ordered list of Stages, and
/// Opportunities (deals) move across those stages on a kanban board. Soft
/// references (plain String, no cross-model FK) to the workspace, the owning rep
/// (MarketingUser) and the originating Lead match this schema's no-cross-FK
/// convention; the Pipeline→Stage→Opportunity links ARE real relations (intra
/// feature) so deleting a pipeline cascades its stages and a stage in use can't
/// be dropped out from under live deals.
model Pipeline {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  position    Int      @default(0) // order among the workspace's pipelines
  isDefault   Boolean  @default(false) // the pipeline new opportunities land in by default
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages        PipelineStage[]
  opportunities Opportunity[]

  @@index([workspaceId])
  @@index([workspaceId, archived])
  @@map("pipelines")
}

/// A single column on a pipeline's kanban board. `probability` is an advisory
/// 0-100 forecast weight; `isWon`/`isLost` mark terminal stages so moving a deal
/// into one resolves it (sets Opportunity.status + wonAt/lostAt).
model PipelineStage {
  id          String   @id @default(uuid())
  workspaceId String
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name        String
  position    Int      @default(0) // order within the pipeline (left→right)
  probability Int      @default(0) // 0-100 advisory win likelihood for forecasting
  isWon       Boolean  @default(false)
  isLost      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  opportunities Opportunity[]

  @@index([workspaceId])
  @@index([pipelineId, position])
  @@map("pipeline_stages")
}

/// A deal moving through a pipeline. `value`/`currency` drive forecasting;
/// `position` orders the card within its stage column (kanban). `leadId` and
/// `assignedToId` are soft references (no FK) like the rest of the schema.
/// `status`: OPEN | WON | LOST | ABANDONED — kept in sync with the stage's
/// isWon/isLost flags by the service.
model Opportunity {
  id          String        @id @default(uuid())
  workspaceId String
  pipelineId  String
  pipeline    Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId     String
  stage       PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)

  leadId       String? // soft ref to leads.id (the originating contact), nullable
  assignedToId String? // soft ref to marketing_users.id (owning rep), nullable

  name              String
  value             Decimal   @default(0) @db.Decimal(12, 2) // monetary value for forecasting
  currency          String    @default("TRY") // TRY | USD | EUR
  status            String    @default("OPEN") // OPEN | WON | LOST | ABANDONED
  source            String?
  notes             String?   @db.Text
  position          Int       @default(0) // order within the stage column (lower = top)
  lostReason        String?
  /// Forecasting (GHL parity): when the rep expects this deal to close. Drives
  /// the time-phased forecast month buckets; nullable = unscheduled.
  expectedCloseDate DateTime?
  wonAt             DateTime?
  lostAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, pipelineId, stageId, position])
  @@index([workspaceId, status])
  @@index([assignedToId])
  @@index([leadId])
  @@map("opportunities")
}

/// Epic — Products catalog (GoHighLevel parity). Reusable priced items a
/// workspace sells: attached to invoices/estimates/order-forms (later epics)
/// and opportunities. `billingType` ONE_TIME | RECURRING (interval MONTH|YEAR);
/// `price` is in the currency's major unit (e.g. 99.90 TRY). Soft workspace
/// scoping (no cross-FK), matching the rest of the schema. Archive (active=false)
/// instead of delete so historical line items keep resolving.
model Product {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  description String?  @db.Text
  sku         String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  currency    String   @default("TRY") // TRY | USD | EUR
  billingType String   @default("ONE_TIME") // ONE_TIME | RECURRING
  interval    String? // MONTH | YEAR (set when billingType=RECURRING)
  taxRate     Decimal? @db.Decimal(5, 2) // optional VAT/tax percent
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, active])
  @@map("products")
}

/// Epic — Estimates / quotes (GoHighLevel parity). A priced document of line
/// items sent to a lead/customer who can accept or decline; an accepted estimate
/// converts to an Invoice (convertedInvoiceId, a soft no-FK link). Mirrors the
/// Invoice shape: `items` is a JSON array of { description, qty, unitPrice }
/// (minor units), `total` is the computed minor-unit sum, `publicToken` backs the
/// customer accept/decline page. Soft workspace scoping.
model Estimate {
  id                 String    @id @default(uuid())
  workspaceId        String
  leadId             String?
  number             String
  items              Json
  currency           String    @default("TRY")
  subtotal           Int       @default(0) // minor units
  taxTotal           Int       @default(0) // minor units
  total              Int       @default(0) // minor units (kuruş/cents)
  notes              String?
  validUntil         DateTime?
  status             String    @default("DRAFT") // DRAFT | SENT | ACCEPTED | DECLINED | EXPIRED
  publicToken        String    @unique
  acceptedAt         DateTime?
  declinedAt         DateTime?
  convertedInvoiceId String? // set once converted to an invoice (soft ref)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@map("estimates")
}

/// Epic — E-signature Documents / Contracts (GoHighLevel parity). A manager
/// authors a document, SENDS it (freezes a body snapshot + consent statement and
/// mints a public token), and a signer reviews the frozen body, types their full
/// name, checks an explicit consent box and signs. Records a simple
/// electronic-signature audit trail (name/email/ip/user-agent/timestamp +
/// frozen consent + body snapshot — kept PLAINTEXT on purpose: it is legal
/// evidence that must be inspectable, not a secret). `body` is plain text,
/// rendered escaped (no HTML injection). `publicToken` is null until SENT.
/// Soft workspace scoping (no FK).
model Document {
  id          String  @id @default(uuid())
  workspaceId String
  leadId      String? // soft ref (no FK), standalone allowed

  type  String @default("AGREEMENT") // AGREEMENT | CONSENT | SERVICE_FORM
  title String
  body  String @db.Text // manager-authored plain text; rendered escaped + pre-wrap

  status      String  @default("DRAFT") // DRAFT | SENT | SIGNED | DECLINED | VOIDED
  publicToken String? @unique // null until SENT (Postgres allows many NULLs)

  // Frozen-at-send evidence (immutable record of WHAT was presented):
  bodySnapshot     String?   @db.Text
  consentStatement String?   @db.Text
  sentAt           DateTime?

  // Legal audit trail — written once, at sign (plaintext on purpose):
  signerName      String?
  signerEmail     String?
  signedAt        DateTime?
  signerIp        String?
  signerUserAgent String?   @db.Text

  declinedAt DateTime?
  voidedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, status])
  @@index([leadId])
  @@map("documents")
}

/// Epic — Public payment-enabled Order Forms (GoHighLevel parity). A
/// manager-authored config (template, NOT a per-buyer record): a public page
/// where a buyer enters name/email/phone and submits → the server creates-or-
/// dedupes a Lead (via the audited public lead-ingest pattern), creates an
/// Invoice for the configured product/items, and redirects the buyer to the
/// existing invoice pay page. Pricing is `productId` XOR `items` — the buyer can
/// NEVER influence the amount (resolved server-side at submit). `publicToken` is
/// minted at create (the form is meant to be shared). Soft workspace scoping.
model OrderForm {
  id          String  @id @default(uuid())
  workspaceId String
  name        String
  productId   String? // soft ref to a Product; server resolves its live price at submit
  items       Json? // fixed [{description,qty,unitPrice}] minor units; XOR productId
  currency    String  @default("TRY") // TRY | USD | EUR

  collectPhone  Boolean @default(true)
  phoneRequired Boolean @default(false)
  notes         String? @db.Text

  publicToken String  @unique // always-on share token (the public-page capability)
  active      Boolean @default(true) // inactive → public page 404s

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, active])
  @@index([workspaceId, createdAt])
  @@map("order_forms")
}

/// Epic — Ads reporting (GoHighLevel parity). A workspace connects its OWN Meta
/// Ads / TikTok Ads account (per-tenant: the platform holds one app, each
/// workspace pastes/grants its own ad-account access token, sealed). A periodic
/// sweep pulls spend/impressions/clicks/leads into AdMetric for reporting. The
/// token is SEALED (secret-box); never echoed. Env-gated / inert without creds.
model AdAccount {
  id             String    @id @default(uuid())
  workspaceId    String
  provider       String // META | TIKTOK
  externalAdId   String // act_<id> (Meta) / advertiser_id (TikTok)
  displayName    String
  accessToken    String    @db.Text // SEALED
  refreshToken   String?   @db.Text // SEALED (OAuth auto-discovery — follow-up)
  tokenExpiresAt DateTime?
  status         String    @default("ACTIVE") // ACTIVE | TOKEN_EXPIRED | DISCONNECTED
  currency       String?
  // Meta Conversions API (CAPI) destination. pixelId is the dataset id we POST
  // server-side conversion events to (/<pixelId>/events) — non-secret. capiToken
  // is an OPTIONAL dedicated System-User token (SEALED); when unset the sealed
  // accessToken is reused. Feeding real CRM outcomes (won/paid) back to Meta.
  pixelId        String?
  capiToken      String?   @db.Text // SEALED
  lastPulledAt   DateTime?
  lastError      String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  metrics AdMetric[]
  rules   AdRule[]

  @@unique([workspaceId, provider, externalAdId])
  @@index([workspaceId, provider])
  @@index([status, lastPulledAt])
  @@map("ad_accounts")
}

/// A per-day (optionally per-campaign) rollup of ad metrics pulled from the
/// provider. Idempotent upsert on (adAccountId, date, campaignId) so a re-pull
/// never duplicates. `spend` is in the account currency's major unit.
model AdMetric {
  id              String    @id @default(uuid())
  workspaceId     String
  adAccountId     String
  adAccount       AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  date            DateTime  @db.Date // UTC day
  campaignId      String    @default("") // '' = account-level rollup
  spend           Decimal   @default(0) @db.Decimal(14, 2)
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  leads           Int       @default(0)
  /// Faz 5/7 Performance Loop: revenue & conversion value pulled from the
  /// provider (or reconciled from CRM won-revenue); roas = revenue / spend.
  revenue         Decimal   @default(0) @db.Decimal(14, 2)
  conversionValue Decimal   @default(0) @db.Decimal(14, 2)
  roas            Decimal?  @db.Decimal(10, 4)
  rawMetrics      Json?
  pulledAt        DateTime  @default(now())

  @@unique([adAccountId, date, campaignId])
  @@index([workspaceId, date])
  @@map("ad_metrics")
}

/// An automated ad-scaling rule (Meta only). The hourly evaluator computes
/// `metric` over the trailing `windowDays` per campaign and, when the condition
/// holds (respecting per-campaign `cooldownHours`), applies `action`:
/// INCREASE_BUDGET / DECREASE_BUDGET (by `actionValue` %, clamped to min/max),
/// PAUSE or RESUME. Every firing is recorded in AdRuleLog.
model AdRule {
  id              String    @id @default(uuid())
  workspaceId     String
  adAccountId     String
  account         AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  name            String
  enabled         Boolean   @default(true)
  level           String    @default("CAMPAIGN") // CAMPAIGN (adset = follow-up)
  metric          String // SPEND | CPL | CTR | LEADS | CLICKS | IMPRESSIONS
  operator        String // GT | LT | GTE | LTE
  threshold       Decimal   @db.Decimal(14, 2)
  windowDays      Int       @default(3)
  action          String // INCREASE_BUDGET | DECREASE_BUDGET | PAUSE | RESUME
  actionValue     Decimal?  @db.Decimal(10, 2) // percent for budget actions
  maxBudget       Decimal?  @db.Decimal(14, 2) // major units (budget ceiling)
  minBudget       Decimal?  @db.Decimal(14, 2) // major units (budget floor)
  cooldownHours   Int       @default(24)
  lastRunAt       DateTime?
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  logs AdRuleLog[]

  @@index([workspaceId, adAccountId])
  @@index([enabled])
  @@map("ad_rules")
}

/// Audit of each ad-rule firing (what entity, what action, before→after, ok?).
model AdRuleLog {
  id          String   @id @default(uuid())
  workspaceId String
  ruleId      String
  rule        AdRule   @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  entityId    String // campaign/adset id acted on
  entityName  String?
  action      String
  detail      String?  @db.Text // e.g. "daily_budget 100.00 → 120.00"
  ok          Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([workspaceId, ruleId])
  @@index([ruleId, entityId, action, createdAt])
  @@map("ad_rule_logs")
}

/// Unit price of a billable growth channel (Budget Autopilot, Faz 7). A NULL
/// `workspaceId` is a platform default; a workspace row overrides it. Rows are
/// versioned by `effectiveFrom` (keep history; resolve the latest active ≤ now),
/// so `unitCost` prices raw counts — SMS segments, WhatsApp category×country,
/// voice minutes, fal credits — into currency for a single growth budget.
model ChannelTariff {
  id            String   @id @default(uuid())
  workspaceId   String? // null = platform default
  channel       String // SMS | WHATSAPP | VOICE | CONTENT
  provider      String? // netgsm | meta | fal | ...
  unitType      String // SMS_SEGMENT | WA_MARKETING | WA_UTILITY | WA_SERVICE | VOICE_MINUTE | FAL_CREDIT
  unitCost      Decimal  @db.Decimal(14, 4)
  currency      String   @default("TRY")
  country       String? // ISO-2, for WhatsApp category×country pricing
  effectiveFrom DateTime @default(now())
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([channel, unitType, active, effectiveFrom])
  @@index([workspaceId, channel, unitType])
  @@map("channel_tariffs")
}

/// Append-only, tenant-scoped MONEY ledger for the Budget Autopilot (Faz 7).
/// Every ad-budget write, message, call and content generation debits here at
/// its real unit cost (`delta` < 0); refunds/adjusts credit (`delta` > 0).
/// `balanceAfter` snapshots the running period spend so pacing reads are O(1).
model SpendLedger {
  id           String   @id @default(uuid())
  workspaceId  String
  budgetId     String? // GrowthBudget period, when one is active (Faz 7)
  channel      String // META | TIKTOK | GOOGLE | LINKEDIN | CONTENT | SMS | VOICE | WHATSAPP
  delta        Decimal  @db.Decimal(14, 2) // signed: <0 spend, >0 refund/credit
  unitCost     Decimal? @db.Decimal(14, 4)
  quantity     Decimal? @db.Decimal(14, 4)
  reason       String // AD_WRITE | SMS | VOICE | WHATSAPP | CONTENT_GEN | REFUND | ADJUST
  ref          String? // campaign / message / call / generation id
  balanceAfter Decimal  @db.Decimal(14, 2)
  createdAt    DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, budgetId, channel])
  @@index([ref])
  @@map("spend_ledgers")
}

/// Prepaid growth credit (Growth Autopilot). ONE wallet per workspace; the
/// balance is the credit the autonomous engine may still commit. Cached
/// `balance` is mutated ONLY together with an append-only ledger entry, and a
/// debit uses a conditional updateMany (balance >= amount) so it is race-safe
/// and can NEVER go negative (fail-closed). Distinct from CustomerWallet
/// (end-customer store credit) — do not conflate.
model GrowthWallet {
  id          String   @id @default(uuid())
  workspaceId String   @unique
  balance     Decimal  @default(0) @db.Decimal(14, 2)
  currency    String   @default("TRY")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries GrowthWalletLedgerEntry[]

  @@map("growth_wallets")
}

/// Append-only audit trail for GrowthWallet. `ref` is globally unique so money
/// movements are idempotent: a replayed top-up webhook (`order:{id}`) or a
/// re-run ad-spend mirror (`admetric:{campaign}:{day}`) credits/debits ONCE.
/// kind: TOPUP | ENGINE_SPEND | AD_GOVERNOR (non-cash ad bookkeeping) |
/// REFUND | ADJUST.
model GrowthWalletLedgerEntry {
  id           String       @id @default(uuid())
  workspaceId  String
  walletId     String
  wallet       GrowthWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  delta        Decimal      @db.Decimal(14, 2) // signed: >0 credit, <0 debit
  balanceAfter Decimal      @db.Decimal(14, 2)
  kind         String // TOPUP | ENGINE_SPEND | AD_GOVERNOR | REFUND | ADJUST
  ref          String?      @unique
  note         String?
  createdAt    DateTime     @default(now())

  @@index([workspaceId, createdAt])
  @@map("growth_wallet_ledger_entries")
}

/// The single growth budget a workspace gives the Budget Autopilot for a month
/// (Faz 7). `totalAmount` is the hard cap the autopilot may NEVER exceed.
/// `scope` = HOLISTIC (ads + content + conversations) or AD_ONLY. `killSwitch`
/// halts all autonomous spend instantly. `explorationPct` is held back for
/// learning; `targetRoas`/`targetCac` are the optimization floor.
model GrowthBudget {
  id             String   @id @default(uuid())
  workspaceId    String
  periodKey      String // YYYY-MM
  currency       String   @default("TRY")
  totalAmount    Decimal  @db.Decimal(14, 2)
  scope          String   @default("HOLISTIC") // HOLISTIC | AD_ONLY
  status         String   @default("ACTIVE") // ACTIVE | PAUSED | KILLED
  killSwitch     Boolean  @default(false)
  explorationPct Int      @default(20)
  allocatorStage String   @default("MARGINAL") // MARGINAL | BANDIT | MMM — which allocator the autopilot uses
  /// Autonomy lane (Growth Autopilot): SHADOW = record proposals only;
  /// ASSISTED = propose + human approval queue (the pre-autopilot default);
  /// AUTONOMOUS = propose → auto-apply under machine guardrails, no approvals.
  autonomyLevel  String   @default("ASSISTED") // SHADOW | ASSISTED | AUTONOMOUS
  /// Content-arm safety gate (Growth Autopilot). FALSE (default) = the engine
  /// provisions content campaigns as SEMI_AUTO — each post surfaces in the
  /// approval queue and auto-publishes unless the user rejects it in the
  /// window ("show before posting", since autonomous posting can't be undone
  /// by the kill-switch). TRUE = FULL_AUTO, pure never-ask. Ad reallocation is
  /// unaffected (it's reversible and always follows autonomyLevel).
  contentAutoPublish Boolean @default(false)
  targetRoas     Decimal? @db.Decimal(10, 4)
  targetCac      Decimal? @db.Decimal(14, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  allocations BudgetAllocation[]

  @@unique([workspaceId, periodKey])
  @@index([status])
  @@map("growth_budgets")
}

/// One channel/campaign slice of a GrowthBudget. `plannedAmount` is what the
/// allocator assigned; `spentAmount` is settled from SpendLedger; `marginalRoas`
/// is the last estimate driving reallocation. `campaignRef` '' = channel-level.
model BudgetAllocation {
  id            String       @id @default(uuid())
  workspaceId   String
  budgetId      String
  budget        GrowthBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  channel       String // META | TIKTOK | GOOGLE | LINKEDIN | CONTENT | SMS | VOICE | WHATSAPP
  campaignRef   String       @default("") // '' = channel-level rollup
  plannedAmount Decimal      @default(0) @db.Decimal(14, 2)
  spentAmount   Decimal      @default(0) @db.Decimal(14, 2)
  marginalRoas  Decimal?     @db.Decimal(10, 4)
  lastPacedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([budgetId, channel, campaignRef])
  @@index([workspaceId, channel])
  @@map("budget_allocations")
}

/// Audit of every Budget Autopilot decision (generalizes AdRuleLog to the
/// decision level). Records the before→after allocation, the marginal-ROAS/CAC
/// snapshot that justified it, whether it ran AUTO or needed APPROVED, and the
/// approval/reversal linkage — so "why did the AI move my money?" is answerable.
model AutopilotRun {
  id                String   @id @default(uuid())
  workspaceId       String
  budgetId          String?
  kind              String // PACING | REALLOCATION | LAUNCH | TARGET_CHANGE
  objective         Json? // marginal-ROAS/CAC snapshot
  before            Json?
  after             Json?
  autonomy          String   @default("AUTO") // AUTO | APPROVED | SHADOW
  approvalRequestId String?
  approvedBy        String?
  ok                Boolean  @default(true)
  reversedById      String?
  createdAt         DateTime @default(now())

  @@index([workspaceId, budgetId, createdAt])
  @@map("autopilot_runs")
}

/// Budget-pacing controller state (Budget Autopilot, Faz 7). One row per
/// (budget, channel) — channel '' = whole-budget pacing. Persists the PID
/// controller's integral/last-error across ticks so spend is smoothed toward
/// the ideal curve (avoids front-loading the budget early or starving it late).
model PacingState {
  id                  String    @id @default(uuid())
  workspaceId         String
  budgetId            String
  channel             String    @default("") // '' = whole-budget
  spentToDate         Decimal   @default(0) @db.Decimal(14, 2)
  idealToDate         Decimal   @default(0) @db.Decimal(14, 2)
  pidIntegral         Decimal   @default(0) @db.Decimal(16, 6)
  pidLastError        Decimal   @default(0) @db.Decimal(16, 6)
  recommendedDailyCap Decimal?  @db.Decimal(14, 2)
  status              String    @default("ON_PACE") // ON_PACE | UNDERSPENDING | OVERSPENDING
  lastPacedAt         DateTime?
  updatedAt           DateTime  @updatedAt

  @@unique([budgetId, channel])
  @@map("pacing_states")
}

/// One invocation of a role-specialized marketing agent (Faz 3 multi-agent
/// observability). Answers "why did the AI do this?": input/output, status,
/// token/credit cost, and the parent run for agent-to-agent handoff chains.
model AgentRun {
  id          String        @id @default(uuid())
  workspaceId String
  agent       String // researcher | strategist | copywriter | video-director | publisher | analyst | optimizer | compliance
  goal        String?       @db.Text
  status      String        @default("RUNNING") // RUNNING | DONE | FAILED
  input       Json?
  output      Json?
  error       String?       @db.Text
  costCredits Int           @default(0)
  tokensIn    Int           @default(0)
  tokensOut   Int           @default(0)
  parentRunId String? // agent-to-agent handoff chain
  startedAt   DateTime      @default(now())
  finishedAt  DateTime?
  toolCalls   ToolCallLog[]

  @@index([workspaceId, agent, startedAt])
  @@index([workspaceId, status])
  @@map("agent_runs")
}

/// A single tool call made during an AgentRun (Faz 3). Args/result/latency per
/// call so every side effect an agent triggered is auditable.
model ToolCallLog {
  id          String   @id @default(uuid())
  workspaceId String
  runId       String
  run         AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  tool        String
  args        Json?
  result      Json?
  ok          Boolean  @default(true)
  error       String?  @db.Text
  latencyMs   Int?
  createdAt   DateTime @default(now())

  @@index([runId, createdAt])
  @@map("tool_call_logs")
}

/// The unified human-approval queue (Faz 3). Any high-risk action an agent (or
/// the Budget Autopilot) wants to take above its autonomy threshold —
/// reallocation, publish, send, ad-spend, target change — enqueues here and only
/// executes once an OWNER/MANAGER approves. `payload` carries the action to apply.
model ApprovalRequest {
  id               String    @id @default(uuid())
  workspaceId      String
  kind             String // BUDGET_REALLOCATION | PUBLISH | SEND | AD_SPEND | TARGET_CHANGE | CHANNEL_LAUNCH
  status           String    @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED | APPLIED
  summary          String    @db.Text
  payload          Json
  requestedByRunId String?
  resourceType     String?
  resourceId       String?
  decidedById      String?
  decidedAt        DateTime?
  appliedAt        DateTime?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([workspaceId, status, createdAt])
  @@map("approval_requests")
}

/// A prospecting audit (GHL parity, Epic 13 — inert until PAGESPEED_API_KEY).
/// A workspace user points the tool at a prospect's website; an async
/// ScheduledJob grades the page (on-page SEO + Google PageSpeed) into `sections`
/// and the unguessable `publicToken` exposes a branded report that can be
/// converted to a Lead (idempotent via `convertedLeadId`).
model ProspectAudit {
  id              String    @id @default(uuid())
  workspaceId     String
  targetUrl       String
  businessName    String?
  status          String    @default("PENDING") // PENDING | RUNNING | DONE | FAILED
  score           Int? // 0–100 overall, null until DONE
  sections        Json? // AuditSection[] — per-check scores + findings
  error           String?
  publicToken     String    @unique
  convertedLeadId String? // set once when converted to a lead (idempotent)
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([workspaceId, status])
  @@map("prospect_audits")
}

/// A workspace's own email sending domain (GHL parity, Epic 13 — inert until
/// SENDING_DOMAIN_ESP). We mint an RSA DKIM keypair (private sealed, public
/// published in the DKIM TXT record); a verify job re-polls DNS until DKIM/SPF/
/// DMARC appear. Once VERIFIED, marketing email can be sent From this domain.
model SendingDomain {
  id                String    @id @default(uuid())
  workspaceId       String
  domain            String
  status            String    @default("PENDING") // PENDING | VERIFIED | FAILED
  fromEmail         String? // the From address used once VERIFIED (noreply@domain)
  fromName          String?
  dkimSelector      String
  dkimPublicKey     String // base64 DER (the DKIM `p=` value we publish)
  dkimPrivateSealed String // AES-GCM-sealed PKCS8 PEM private key (for future signing)
  lastError         String?
  verifiedAt        DateTime?
  providerDomainId  String? // set when an ESP manages the domain
  createdAt         DateTime  @default(now())

  @@unique([workspaceId, domain])
  @@index([workspaceId, status])
  @@map("sending_domains")
}

/// A tenant's own hostname pointed at the platform to white-label its public
/// site (GHL parity, Epic 13 — inert until CUSTOM_DOMAINS_ENABLED + ops wires
/// wildcard ingress + on-demand TLS). hostname is globally unique (one host →
/// one workspace); a verify sweep flips PENDING→VERIFIED once the DNS TXT token
/// is published, after which the Host-header middleware serves the workspace's
/// public SitePage for that host.
model CustomDomain {
  id            String    @id @default(uuid())
  workspaceId   String
  hostname      String    @unique
  verifyToken   String
  homeSlug      String    @default("home") // the SitePage slug served at '/'
  status        String    @default("PENDING") // PENDING | VERIFIED | ACTIVE | FAILED
  txtVerifiedAt DateTime?
  sslStatus     String    @default("PENDING") // PENDING | ISSUED (ACME/ops-managed)
  lastError     String?
  lastCheckedAt DateTime? // verify-sweep cursor (nulls-first ordering = anti-starvation)
  createdAt     DateTime  @default(now())

  @@index([workspaceId])
  @@map("custom_domains")
}
